---
/**
 * /blog/[slug]/ — динамическая страница статьи блога.
 *
 * Реализация по outline `02_content/page_outlines/29-blog-skolko-vremeni-termopaket-derzhit-kholod.md`.
 * Schema.org: Article (или BlogPosting) + BreadcrumbList.
 *
 * Wave 1 — единственная статья (SEO-якорь). Wave 2 — расширяется через blog collection.
 */

import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/molecules/Breadcrumbs.astro';
import Chip from '@components/molecules/Chip.astro';
import StickyWhatsApp from '@components/organisms/StickyWhatsApp.astro';
import PreFooterCta from '@components/organisms/PreFooterCta.astro';
import { article, breadcrumbList } from '@lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

const siteUrl = Astro.site?.toString() ?? 'https://termybrand.com/';
const pageUrl = `${siteUrl.replace(/\/$/, '')}${Astro.url.pathname}`;

const breadcrumbs = [
  { name: 'Главная', url: siteUrl },
  { name: 'Блог',    url: `${siteUrl}blog/` },
  { name: post.data.title, url: pageUrl },
];

const datePublished = post.data.pubDate.toISOString();
const dateModified = (post.data.updatedDate ?? post.data.pubDate).toISOString();

const schema = [
  article({
    headline: post.data.title,
    url: pageUrl,
    datePublished,
    dateModified,
    imageUrl: post.data.cover ? `${siteUrl.replace(/\/$/, '')}${post.data.cover}` : undefined,
    articleSection: post.data.articleSection,
    authorName: 'TERMY',
  }),
  breadcrumbList(breadcrumbs),
];

function formatDateRu(iso: string): string {
  return new Intl.DateTimeFormat('ru-RU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(new Date(iso));
}

// Reading time (грубая оценка: 1000 знаков ≈ 1 минута)
const bodyLength = post.body?.length ?? 0;
const readingMin = Math.max(1, Math.round(bodyLength / 1500));
---

<BaseLayout
  title={post.data.metaTitle}
  description={post.data.metaDescription}
  ogType="article"
  ogImage={post.data.cover}
  schema={schema}
>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <article class="art" itemscope itemtype="https://schema.org/Article">
    <header class="art__hero">
      <div class="container art__hero-inner">
        {post.data.tags.length > 0 && (
          <ul class="art__tags" role="list">
            {post.data.tags.map((t) => (
              <li><Chip variant="default" size="sm">{t}</Chip></li>
            ))}
          </ul>
        )}

        <h1 class="art__h1" itemprop="headline">{post.data.title}</h1>

        <p class="art__excerpt">{post.data.excerpt}</p>

        <p class="art__meta">
          <time datetime={datePublished} itemprop="datePublished">{formatDateRu(datePublished)}</time>
          <span class="art__sep" aria-hidden="true">·</span>
          <span>{readingMin} мин чтения</span>
          {post.data.articleSection && (
            <>
              <span class="art__sep" aria-hidden="true">·</span>
              <span itemprop="articleSection">{post.data.articleSection}</span>
            </>
          )}
        </p>
      </div>
    </header>

    <div class="container art__body" itemprop="articleBody">
      <Content />
    </div>

    {/* Related products / cross-cluster */}
    <aside class="art__related" aria-labelledby="art-related-h">
      <div class="container">
        <h2 id="art-related-h" class="art__related-h">Связанные продукты и решения</h2>
        <ul class="art__related-list" role="list">
          <li><a href="/products/termopakety/" class="art__related-link">Каталог термопакетов →</a></li>
          <li><a href="/products/akkumulyatory-holoda/" class="art__related-link">Аккумуляторы SHOCK® →</a></li>
          <li><a href="/solutions/dostavka/" class="art__related-link">Решения для доставки →</a></li>
          <li><a href="/blog/" class="art__related-link">← Все статьи</a></li>
        </ul>
      </div>
    </aside>
  </article>

  <PreFooterCta
    heading="Нужен расчёт под ваш маршрут?"
    lead="Опишите задачу — пришлём комплект (термопакет + SHOCK®) под маршрут и температурный режим."
    primaryCta={{ label: 'Получить расчёт →', href: '/contacts/' }}
    secondaryCta={{ label: 'Открыть каталог →', href: '/products/' }}
  />

  <StickyWhatsApp />
</BaseLayout>

<style>
  .art { padding-block-end: var(--spacing-7); background: var(--color-bg-page); }

  .art__hero {
    padding-block: var(--spacing-6) var(--spacing-7);
    background: var(--color-bg-surface-warm);
    border-block-end: 1px solid var(--color-border-subtle);
  }
  .art__hero-inner {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }
  .art__tags { display: flex; flex-wrap: wrap; gap: var(--spacing-2); margin: 0; padding: 0; list-style: none; }
  .art__h1 {
    margin: 0;
    font-size: var(--font-size-h1-fluid);
    font-weight: var(--font-weight-bold);
    line-height: var(--font-line-height-tight);
    letter-spacing: var(--font-letter-spacing-tighter);
    color: var(--color-text-primary);
  }
  .art__excerpt {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--font-size-md);
    line-height: var(--font-line-height-normal);
  }
  .art__meta {
    margin: 0;
    color: var(--color-text-tertiary);
    font-size: var(--font-size-sm);
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    align-items: center;
  }
  .art__sep { opacity: 0.6; }

  /* Body — prose-style */
  .art__body {
    max-width: 720px;
    padding-block: var(--spacing-7);
  }
  .art__body :global(h2) {
    margin-block: var(--spacing-7) var(--spacing-3);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--font-line-height-snug);
    color: var(--color-text-primary);
    scroll-margin-block-start: var(--spacing-6);
  }
  .art__body :global(h2:first-child) { margin-block-start: 0; }
  .art__body :global(h3) {
    margin-block: var(--spacing-5) var(--spacing-2);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
  }
  .art__body :global(p) {
    margin-block: var(--spacing-3);
    color: var(--color-text-primary);
    font-size: var(--font-size-md);
    line-height: var(--font-line-height-loose);
  }
  .art__body :global(ul),
  .art__body :global(ol) {
    margin-block: var(--spacing-4);
    padding-inline-start: var(--spacing-5);
    color: var(--color-text-primary);
    line-height: var(--font-line-height-normal);
  }
  .art__body :global(li) { margin-block: var(--spacing-2); }
  .art__body :global(a) {
    color: var(--color-action-primary);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
    transition: text-decoration-thickness var(--duration-fast) var(--easing-standard);
  }
  .art__body :global(a:hover),
  .art__body :global(a:focus-visible) { text-decoration-thickness: 2px; }
  .art__body :global(strong) {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }
  .art__body :global(blockquote) {
    margin: var(--spacing-5) 0;
    padding: var(--spacing-4) var(--spacing-5);
    border-inline-start: 4px solid var(--color-action-primary);
    background: var(--color-bg-surface-warm);
    color: var(--color-text-primary);
    font-size: var(--font-size-md);
    line-height: var(--font-line-height-normal);
    border-radius: 0 var(--radius-base) var(--radius-base) 0;
  }
  .art__body :global(blockquote p) { margin: 0; }
  .art__body :global(table) {
    width: 100%;
    margin-block: var(--spacing-5);
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }
  .art__body :global(thead th) {
    padding: var(--spacing-3);
    background: var(--color-bg-surface);
    text-align: left;
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    border-block-end: 2px solid var(--color-border-default);
  }
  .art__body :global(tbody td) {
    padding: var(--spacing-3);
    border-block-end: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    vertical-align: top;
  }

  .art__related {
    padding-block: var(--spacing-7);
    background: var(--color-bg-surface);
    border-block-start: 1px solid var(--color-border-subtle);
  }
  .art__related-h {
    margin-block-end: var(--spacing-4);
    font-size: var(--font-size-md);
  }
  .art__related-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .art__related-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: var(--spacing-2) var(--spacing-4);
    background: var(--color-bg-page);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-base);
    color: var(--color-action-primary);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: border-color var(--duration-fast) var(--easing-standard);
  }
  .art__related-link:hover,
  .art__related-link:focus-visible { border-color: var(--color-action-primary); }

  @media (min-width: 768px) {
    .art__related-list { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .art__related-list { grid-template-columns: repeat(4, 1fr); }
  }

  @media (prefers-reduced-motion: reduce) {
    .art__body :global(a),
    .art__related-link { transition: none; }
    html { scroll-behavior: auto; }
  }
</style>
