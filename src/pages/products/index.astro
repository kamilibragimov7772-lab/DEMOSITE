---
/**
 * /products/ — Единый каталог TERMY (replaces 6 category-hub pages).
 *
 * Архитектура: одна страница, top-chips переключают категорию, sidebar-фильтры,
 * SKU-grid справа. Фильтры — client-side через `<script>`, URL-sync `?cat=...&size=...`.
 * Источник истины — `src/data/catalog.ts`.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/molecules/Breadcrumbs.astro';
import CatalogPage from '@components/organisms/CatalogPage.astro';
import FaqAccordion from '@components/organisms/FaqAccordion.astro';
import FormBlock from '@components/organisms/FormBlock.astro';
import PreFooterCta from '@components/organisms/PreFooterCta.astro';
import StickyWhatsApp from '@components/organisms/StickyWhatsApp.astro';
import { collectionPage, breadcrumbList, faqPage, itemList } from '@lib/schema';
import { SKUS } from '@data/catalog';

const siteUrl = Astro.site?.toString() ?? 'https://termybrand.com/';

const faqItems = [
  { question: 'От какого MOQ можно заказать?',
    answer: 'От 1 коробки на термопакеты Light/Standart/PRO и SHOCK®. Брендирование шелкографией — от 500 шт, флексопечать — от 10 000 шт, наклейки SHOCK® — от 1 000 шт. Точные MOQ — в карточке каждого SKU.' },
  { question: 'Из чего сделаны термопакеты?',
    answer: 'Трёхслойная конструкция: внешний металлизированный (85 мкм) + средний ВПЭ/ВПП + внутренний ПВД 45 мкм или Мет 85 мкм. Серия PRO имеет ВПП 1 см. Все слои — пищевой контакт по ТР ТС 005/2011.' },
  { question: 'Чем отличаются Light, Standart, PRO?',
    answer: 'Light — бюджетная серия, до 4 ч термоизоляции, белая квадратная ручка. Standart — основная линейка, до 4 ч (ПВД) или 7 ч (Мет), чёрная анатомическая ручка-защёлка. PRO — ВПП 1 см, до 7 ч.' },
  { question: 'Сколько часов держит холод комплект «пакет + SHOCK»?',
    answer: 'В комплекте Standart 42×50 + 2× SHOCK Cool 450 — +2…+8°C до 7 часов при наружной +25°C. Подтверждено протоколом испытаний № 012/A-27/02/25.' },
  { question: 'Какой срок производства брендированной партии?',
    answer: 'От утверждения макета — 2–4 недели для шелкографии, 3–5 недель для флексопечати, 3 недели для наклеек SHOCK®. Серийные SKU без брендирования — отгрузка из МСК за 2-5 рабочих дней.' },
];

const schema = [
  collectionPage({
    name: 'Каталог термоупаковки TERMY',
    description: '6 категорий, более 50 SKU: термопакеты, SHOCK®, БаблПак, термосумки, термошопперы. Фильтры по размеру, цвету, режиму, печати.',
    numberOfItems: SKUS.length,
  }),
  breadcrumbList([
    { name: 'Главная', url: siteUrl },
    { name: 'Каталог', url: `${siteUrl}products/` },
  ]),
  itemList({
    name: 'Каталог термоупаковки TERMY',
    items: SKUS.map((s) => ({
      url: `${siteUrl}products/${s.category}/${s.slug}/`,
      name: s.title,
    })),
  }),
  faqPage(faqItems),
];
---

<BaseLayout
  title="Каталог термоупаковки — 53+ SKU из наличия"
  description="Единый каталог: термопакеты, SHOCK®, БаблПак, термосумки, термошопперы. Более 50 SKU. Фильтры по размеру, цвету, температурному режиму и методу печати."
  ogType="website"
  ogImage={`${siteUrl}assets/og/og-products.jpg`}
  schema={schema}
>
  <Breadcrumbs
    items={[
      { name: 'Главная', href: '/' },
      { name: 'Каталог' },
    ]}
  />

  <CatalogPage />

  <FaqAccordion
    eyebrow="Частые вопросы"
    heading="Частые вопросы по каталогу"
    items={faqItems}
    id="faq"
  />

  <FormBlock
    id="cta"
    variant="lead"
    eyebrow="Получить КП по каталогу"
    heading="Получить КП с прайсом и MOQ"
    description="Менеджер свяжется в течение 2 часов, согласует MOQ и пришлёт прайс по выбранным позициям. Бесплатные образцы — на согласование с курьером."
    submitLabel="Получить КП →"
  />

  <PreFooterCta
    heading="Готовы посчитать?"
    lead="Напишите в WhatsApp — менеджер ответит сразу."
    primaryCta={{ label: 'Написать в WhatsApp', href: 'https://wa.me/78001011525' }}
    secondaryCta={{ label: 'Позвонить +7 (800) 101-15-25', href: 'tel:+78001011525' }}
  />

  <StickyWhatsApp />
</BaseLayout>
