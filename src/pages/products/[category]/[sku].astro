---
/**
 * /products/[category]/[sku]/ — динамический PDP, эталон брендбук v1.
 * Источник дизайна: 06A_PDP_Termopaket_42x50_Brandbook_v1.html (P.1–P.18).
 * SKU-данные: src/data/catalog.ts.
 *
 * Генерирует 53 страницы (по одной на каждый SKU).
 * Конструкция / удержание / capacity показываются ТОЛЬКО для термопакетов;
 * для остальных категорий эти блоки пропущены.
 */

import type { GetStaticPaths } from 'astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/molecules/Breadcrumbs.astro';
import StickyWhatsApp from '@components/organisms/StickyWhatsApp.astro';
import { product, breadcrumbList, faqPage } from '@lib/schema';
import { SKUS, CATEGORIES, LABELS, type SkuRow } from '@data/catalog';

export const getStaticPaths = (() => {
  return SKUS.map((sku) => ({
    params: { category: sku.category, sku: sku.slug },
    props: { sku },
  }));
}) satisfies GetStaticPaths;

const { sku } = Astro.props as { sku: SkuRow };

const siteUrl = Astro.site?.toString() ?? 'https://termybrand.com/';
const pdpUrl = `${siteUrl}products/${sku.category}/${sku.slug}/`;
const categoryLabel = CATEGORIES.find((c) => c.slug === sku.category)?.label ?? 'Каталог';

/* Размеры в той же серии (для size-picker). */
const sizeSiblings = SKUS.filter((s) => s.category === sku.category && s.series === sku.series);

/* Категория-флаги для условного рендера. */
const isTermopaket = sku.category === 'termopakety';

const faqItems = [
  { question: 'Можно ли повторно использовать пакет?',
    answer: 'Материал рассчитан на многоразовое использование при мойке холодной / тёплой водой. Заявленные «30+ циклов» проверяются в durability-тесте — до подписи протокола конкретное число не публикуется.' },
  { question: 'Какая максимальная нагрузка?',
    answer: 'Заявленная — до 10 кг. Это значение помечено как gated до load-теста — мы не подтверждаем число без протокола. При тираже свыше 1000 шт возможна индивидуальная проверка на образце.' },
  { question: 'Сколько часов держит температуру?',
    answer: 'Зависит от условий: ambient, содержимое, вес, количество SHOCK®. См. блок «Удержание температуры» — ждём единый протокол теста. В КП мы указываем расчётный диапазон под ваш сценарий.' },
  { question: 'Подходит ли для доставки пиццы?',
    answer: 'Да — 42×50 вмещает 1 пиццу + напитки. Для горячей доставки рекомендуем дополнительно SHOCK 1000 мл (тепловая версия).' },
  { question: 'Какой минимальный тираж с печатью?',
    answer: 'Шелкография — от 500 шт (до 10 цветов, готовность от 7 дней). Флексопечать — от 10 000 шт (до 10 цветов, фотореалистичная).' },
  { question: 'Есть ли в других цветах?',
    answer: 'Все 11 цветов переключаются picker\'ом в карточке. Серебро (этот SKU) — со склада. Другие цвета — со склада или под заказ (уточняется по наличию).' },
  { question: 'Можно ли получить образец?',
    answer: 'Да, бесплатно. Пришлём коробку с образцами. По МО от 5 коробок — доставка бесплатно.' },
  { question: 'Подходит для контакта с едой?',
    answer: 'Да. Внутренний слой ПВД — Food-contact, ТР ТС 005/2011 + СанПиН. Сканы документов — в блоке «Документы и compliance».' },
];

const schema = [
  product({
    name: sku.title,
    sku: sku.artikul,
    category: categoryLabel,
    description: `${sku.title} (${sku.artikul}) — ${sku.size}, ${LABELS.color[sku.color]}. От ${sku.priceFrom} ₽, ${sku.mozLabel}.`,
    color: LABELS.color[sku.color],
    offers: {
      url: pdpUrl,
      priceCurrency: 'RUB',
      price: String(sku.priceFrom),
      availability: sku.inStock ? 'InStock' : 'PreOrder',
    },
  }),
  breadcrumbList([
    { name: 'Главная', url: siteUrl },
    { name: 'Каталог', url: `${siteUrl}products/` },
    { name: categoryLabel, url: `${siteUrl}products/${sku.category}/` },
    { name: sku.title, url: pdpUrl },
  ]),
  faqPage(faqItems),
];
---

<BaseLayout
  title={`${sku.title} — TERMY`}
  description={`${sku.title} (${sku.artikul}). ${categoryLabel}, ${sku.size}, ${LABELS.color[sku.color]}. От ${sku.priceFrom} ₽, ${sku.mozLabel}. Производство РФ.`}
  ogType="website"
  ogImage={`${siteUrl}assets/og/og-products-${sku.category}.jpg`}
  schema={schema}
>
  <Breadcrumbs
    items={[
      { name: 'Главная', href: '/' },
      { name: 'Каталог', href: '/products/' },
      { name: categoryLabel, href: `/products/${sku.category}/` },
      { name: sku.title },
    ]}
  />

  {/* P.3 Sticky action bar */}
  <div class="pdp-sticky">
    <div class="container pdp-sticky__row">
      <span class="pdp-sticky__sku">
        <strong>{sku.artikul}</strong>
        <span class="pdp-sticky__muted">· {sku.title}</span>
      </span>
      <span class="pdp-sticky__price">
        от <strong>{sku.priceFrom} ₽</strong> · {sku.mozLabel}
      </span>
      <a class="btn btn-primary btn-sm" href="#kp">Запросить КП</a>
    </div>
  </div>

  {/* P.4 Hero — gallery + info */}
  <section class="pdp-hero" aria-labelledby="pdp-h1">
    <div class="container pdp-hero__inner">
      {/* Gallery */}
      <div class="pdp-gallery">
        <div class="pdp-gallery__main">
          <img src={sku.image ?? `/products/_catalog/${sku.slug}.webp`} alt={sku.title} />
        </div>
        <ul class="pdp-gallery__thumbs" role="list">
          <li class="pdp-gallery__thumb is-active">Packshot · front</li>
          <li class="pdp-gallery__thumb">Packshot · 3/4</li>
          <li class="pdp-gallery__thumb">С наполнением</li>
          <li class="pdp-gallery__thumb">С лого (флексо)</li>
          <li class="pdp-gallery__thumb">Макро слоёв</li>
          <li class="pdp-gallery__thumb">▶ Видео 15 с</li>
        </ul>
        <p class="pdp-gallery__note">⚠ Галерея — placeholder. Продакт-съёмка в графике (T-023).</p>
      </div>

      {/* Info column */}
      <div class="pdp-info">
        <span class="pdp-info__eyebrow">{categoryLabel} · {LABELS.series[sku.series]}</span>
        <h1 id="pdp-h1" class="pdp-info__h1">{sku.title}</h1>
        <div class="pdp-info__meta">
          <span class="pdp-info__art">{sku.artikul}</span>
          <span>·</span><span>{sku.size}</span>
          <span>·</span><span>Производство РФ</span>
        </div>

        {/* USP bullets — универсальные + категорийные */}
        <ul class="pdp-usp" role="list">
          {sku.features.includes('food-contact') && (
            <li><span class="pdp-usp__ci">✓</span><div>Food-contact · <strong>ТР ТС 005/2011</strong>. Сканы — в блоке «Документы».</div></li>
          )}
          {isTermopaket && sku.features.includes('three-layer') && (
            <li><span class="pdp-usp__ci">✓</span><div>Трёхслойная конструкция (Мет → ВПЭ → ПВД). Подробно — в секции «Конструкция».</div></li>
          )}
          {sku.features.includes('waterproof') && (
            <li><span class="pdp-usp__ci">✓</span><div>Водостойкий внутри и снаружи.</div></li>
          )}
          {sku.features.includes('reusable') && (
            <li><span class="pdp-usp__ci">✓</span><div>Многоразовый · до 30 циклов.</div></li>
          )}
          {sku.features.includes('gost-50962') && (
            <li><span class="pdp-usp__ci">✓</span><div>ГОСТ Р 50962-96 · действ. до 26.02.2028.</div></li>
          )}
          {isTermopaket && (
            <li><span class="pdp-usp__ci">✓</span><div>Удержание температуры <strong>до 4 часов</strong> · протокол № 012/A-27/02/25</div></li>
          )}
        </ul>

        {/* Picker: size siblings (если в серии 2+ размеров) + color (для термопакетов) */}
        {(sizeSiblings.length > 1 || isTermopaket) && (
          <div class="pdp-picker">
            {sizeSiblings.length > 1 && (
              <div class="pdp-picker__row">
                <span class="pdp-picker__label">Размер</span>
                <div class="pdp-picker__pills">
                  {sizeSiblings.map((s) => (
                    s.slug === sku.slug ? (
                      <span class="pdp-pill is-active">{s.size}</span>
                    ) : (
                      <a class="pdp-pill" href={`/products/${s.category}/${s.slug}/`}>{s.size}</a>
                    )
                  ))}
                </div>
              </div>
            )}
            {isTermopaket && (
              <div class="pdp-picker__row">
                <span class="pdp-picker__label">Цвет</span>
                <div class="pdp-picker__swatches">
                  <button class="pdp-swatch is-active" aria-label={LABELS.color[sku.color]} style={`background:${LABELS.colorSwatch[sku.color]}`}></button>
                  <button class="pdp-swatch" aria-label="Жёлтый" style="background:#F4C842"></button>
                  <button class="pdp-swatch" aria-label="Крафт" style="background:#C19760"></button>
                  <button class="pdp-swatch" aria-label="Красный" style="background:#D23A2F"></button>
                  <button class="pdp-swatch" aria-label="Белый" style="background:#FFFFFF"></button>
                  <button class="pdp-swatch" aria-label="Оранжевый" style="background:#EC7A29"></button>
                  <button class="pdp-swatch" aria-label="Зелёный" style="background:#2F9E4A"></button>
                  <button class="pdp-swatch" aria-label="Синий" style="background:#2B5DB0"></button>
                  <button class="pdp-swatch" aria-label="Чёрный" style="background:#14181C"></button>
                </div>
              </div>
            )}
          </div>
        )}

        {/* Feature chips — динамически из sku.features */}
        <div class="pdp-chips">
          {sku.features.map((f) => (
            <span class="pdp-chip">{LABELS.feature[f]}</span>
          ))}
          {sku.printMethods.includes('silkscreen') && <span class="pdp-chip">Шелкография от 500 шт</span>}
          {sku.printMethods.includes('flexo') && <span class="pdp-chip">Флексо от 10 000 шт</span>}
          {sku.printMethods.includes('sticker') && <span class="pdp-chip">Наклейка от 1 000 шт</span>}
        </div>

        {/* Price / MOQ */}
        <div class="pdp-price">
          <span class="pdp-price__from">от</span>
          <span class="pdp-price__num">{sku.priceFrom} ₽</span>
          <span class="pdp-price__moz">· флексо от 10 000 шт · {sku.mozLabel}</span>
          <a class="pdp-price__link" href="#kp">Все тиражи в КП →</a>
        </div>

        {/* CTA cluster */}
        <div class="pdp-cta">
          <a class="btn btn-primary" href="#kp">Запросить КП</a>
          <a class="btn btn-secondary" href="#kp">Образец</a>
          <a class="btn btn-secondary" href="/products/">В сравнение</a>
        </div>

        {/* Quick docs */}
        <div class="pdp-docs">
          <a href="/assets/docs/catalog.pdf"><span class="pdp-docs__clip">📎</span> Каталог</a>
          {sku.features.includes('tu-22-22-11') && (
            <a href="/assets/docs/tu.pdf"><span class="pdp-docs__clip">📎</span> ТУ 22.22.11-001</a>
          )}
          {sku.features.includes('gost-50962') && (
            <a href="/assets/docs/gost.pdf"><span class="pdp-docs__clip">📎</span> ГОСТ Р 50962-96</a>
          )}
          {sku.features.includes('food-contact') && (
            <a href="/assets/docs/migration-cert.pdf"><span class="pdp-docs__clip">📎</span> Сертификат ТР ТС 005/2011</a>
          )}
          {isTermopaket && (
            <a href="/assets/docs/protocol.pdf"><span class="pdp-docs__clip">📎</span> Протокол № 012/A-27/02/25</a>
          )}
        </div>
      </div>
    </div>
  </section>

  {/* P.5 Essence tiles */}
  <section class="pdp-section">
    <div class="container">
      <h2 class="pdp-h2">Ключевое по SKU</h2>
      <div class="essence-grid">
        <div class="etile"><div class="etile__ico">📜</div><h3>ТР ТС 005/2011</h3><p>Food-contact сертификация. Скан с номером — в разделе «Документы».</p></div>
        <div class="etile"><div class="etile__ico">🎨</div><h3>11 цветов + кастом</h3><p>Шелкография от 500 шт, флексопечать от 10 000 шт. AI-шаблон под SKU за 1 рабочий день.</p></div>
        <div class="etile"><div class="etile__ico">🏭</div><h3>Собственное производство</h3><p>Цех в РФ, 3 стадии контроля качества. Аудит — по согласованию.</p></div>
        <div class="etile"><div class="etile__ico">📦</div><h3>{sku.mozLabel}</h3><p>Стандартный короб. Полная упаковочная единица — в спецификации.</p></div>
        <div class="etile"><div class="etile__ico">🚚</div><h3>Отгрузка по РФ и СНГ</h3><p>Вашей ТК. По МО от 5 коробок — бесплатно.</p></div>
        <div class="etile"><div class="etile__ico">♻</div><h3>Перерабатываемость</h3><p>Технически перерабатываемые материалы при наличии инфраструктуры.</p></div>
      </div>
    </div>
  </section>

  {/* P.6 Specs flat table */}
  <section class="pdp-section">
    <div class="container">
      <div class="pdp-section__head">
        <h2 class="pdp-h2">Технические характеристики</h2>
        <span class="pdp-eyebrow">Плоская таблица · без accordion</span>
      </div>
      <table class="specs-table">
        <tbody>
          <tr><td>Артикул</td><td>{sku.artikul}</td></tr>
          <tr><td>Категория</td><td>{categoryLabel}</td></tr>
          <tr><td>Серия / линейка</td><td>{LABELS.series[sku.series]}</td></tr>
          <tr><td>Размер</td><td>{sku.size}{sku.size.includes('×') && !sku.size.includes('×', sku.size.indexOf('×') + 1) ? ' см' : ''}</td></tr>
          {sku.volumeL !== null && (
            <tr><td>Объём</td><td>{sku.volumeL} л</td></tr>
          )}
          <tr><td>Цвет</td><td>{LABELS.color[sku.color]}</td></tr>
          {sku.tempMode !== 'na' && (
            <tr><td>Температурный режим</td><td>{LABELS.tempMode[sku.tempMode]}</td></tr>
          )}
          {isTermopaket && <>
            <tr><td>Материал (слои)</td><td>Мет внешний / ВПЭ средний / ПВД или Мет внутренний</td></tr>
            <tr><td>Толщина внешний (Мет)</td><td>85 мкм</td></tr>
            <tr><td>Толщина средний (ВПЭ)</td><td>1000 мкм</td></tr>
            <tr><td>Толщина внутренний</td><td>45 мкм (ПВД) или 85 мкм (Мет)</td></tr>
            <tr><td>Макс. нагрузка</td><td>до 15 кг</td></tr>
            <tr><td>Удержание температуры</td><td>до 4 часов (Мет/ВПЭ/ПВД), до 7 ч (Мет/ВПЭ/Мет)</td></tr>
            <tr><td>Тип ручки</td><td>{sku.series === 'light' ? 'Белая квадратная ручка' : 'Чёрная анатомическая ручка-защёлка'}</td></tr>
          </>}
          {sku.category === 'akkumulyatory-holoda' && <>
            <tr><td>Тип корпуса</td><td>Твёрдый пищевой пластик</td></tr>
            <tr><td>Наполнитель</td><td>{sku.color === 'purple' ? 'Гель (КМЦ)' : 'Водно-солевой раствор'}</td></tr>
            <tr><td>Сертификат</td><td>ГОСТ Р 50962-96 (действ. до 26.02.2028)</td></tr>
            <tr><td>Миграция ПВХ</td><td>0,001 мг/л — в 10× ниже нормы</td></tr>
          </>}
          {sku.category === 'bablpak' && <>
            <tr><td>Материал</td><td>ВПП + металлизированная плёнка</td></tr>
            <tr><td>Конструкция</td><td>Воздушно-пузырьковая плёнка с фольгой, двусторонний скотч</td></tr>
          </>}
          {sku.category === 'termoshoppery' && <>
            <tr><td>Материал</td><td>БОПП / спанбонд / БОПП фольга</td></tr>
            <tr><td>Толщина</td><td>280 мкм</td></tr>
            <tr><td>Удержание температуры</td><td>до 2 часов</td></tr>
          </>}
          {sku.category === 'termosumki-bolshie' && <>
            <tr><td>Материал</td><td>Гофрокартон Т24 + ВПП 2 см + ПВД 80 мкм</td></tr>
            <tr><td>Удержание температуры</td><td>до 72 часов</td></tr>
          </>}
          {sku.features.includes('reusable') && (
            <tr><td>Циклы использования</td><td>до 30</td></tr>
          )}
          {sku.features.includes('food-contact') && (
            <tr><td>Food-contact</td><td>ТР ТС 005/2011 · СанПиН</td></tr>
          )}
          {sku.features.includes('tu-22-22-11') && (
            <tr><td>Нормативный документ</td><td>ТУ 22.22.11-001-47645032-2022</td></tr>
          )}
          <tr><td>Страна производства</td><td>Россия (Подмосковье)</td></tr>
          <tr><td>МОЗ без печати</td><td>{sku.mozLabel}</td></tr>
          {(sku.printMethods.includes('silkscreen')) && (
            <tr><td>МОЗ с шелкографией</td><td>от 500 шт</td></tr>
          )}
          {(sku.printMethods.includes('flexo')) && (
            <tr><td>МОЗ с флексопечатью</td><td>от 10 000 шт</td></tr>
          )}
          {(sku.printMethods.includes('sticker')) && (
            <tr><td>МОЗ с наклейкой</td><td>от 1 000 шт</td></tr>
          )}
          <tr><td>Цена «от»</td><td>{sku.priceFrom > 0 ? `${sku.priceFrom} ₽` : 'под запрос'}</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* P.7 Construction (3-layer flat-stack) — только для термопакетов */}
  {isTermopaket && (
  <section class="pdp-section">
    <div class="container">
      <div class="construction">
        <div class="pdp-section__head">
          <h2 class="pdp-h2">Трёхслойная конструкция</h2>
          <span class="pdp-eyebrow">Flat-stack · без cutaway</span>
        </div>
        <p class="construction__caption">
          Каждый слой выполняет свою задачу: внешний мет — защита и поверхность под печать; средний ВПЭ —
          тепловой барьер; внутренний ПВД — отражение тепла + гигиена контакта с едой.
        </p>
        <div class="layer-stack">
          <div class="layer">
            <div class="layer__n">Слой 1 · внешний</div>
            <h3>Мет</h3>
            <div class="layer__viz">
              <svg viewBox="0 0 200 100" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Металлизированная плёнка — отражающая поверхность">
                <defs>
                  <linearGradient id="met-gr" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#EEF1F4"/>
                    <stop offset="40%" stop-color="#9AA3AC"/>
                    <stop offset="60%" stop-color="#CDD5DD"/>
                    <stop offset="100%" stop-color="#7E8790"/>
                  </linearGradient>
                </defs>
                <rect width="200" height="100" fill="url(#met-gr)" rx="6"/>
                <line x1="0" y1="22" x2="200" y2="22" stroke="rgba(255,255,255,0.45)" stroke-width="1"/>
                <line x1="0" y1="48" x2="200" y2="48" stroke="rgba(255,255,255,0.3)" stroke-width="0.8"/>
                <line x1="0" y1="74" x2="200" y2="74" stroke="rgba(255,255,255,0.25)" stroke-width="0.8"/>
                <path d="M 30 35 Q 60 25 90 35 T 150 35" stroke="rgba(255,255,255,0.5)" stroke-width="2" fill="none" stroke-linecap="round"/>
                <path d="M 50 65 Q 90 55 130 65 T 180 65" stroke="rgba(255,255,255,0.35)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="layer__spec">Металлизированная плёнка. Печатная поверхность. Устойчива к влаге и истиранию.</div>
            <div class="layer__micron">85 мкм</div>
          </div>

          <div class="layer">
            <div class="layer__n">Слой 2 · средний</div>
            <h3>ВПЭ</h3>
            <div class="layer__viz">
              <svg viewBox="0 0 200 100" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Вспененный полиэтилен — тепловой барьер с воздушной прослойкой">
                <rect width="200" height="100" fill="#F4F1EA" rx="6"/>
