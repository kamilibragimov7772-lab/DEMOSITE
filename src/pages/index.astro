    question: 'Возможна ли работа по тендеру / 44-ФЗ / 223-ФЗ?',
    answer: 'Да. Участвуем в закупках по 44-ФЗ и 223-ФЗ, имеем опыт работы с госзаказчиками и аккредитованными площадками (Сбербанк-АСТ, Росэлторг, ЕЭТП). Готовим полный пакет документов для тендерных комиссий: ТУ, протоколы испытаний, сертификаты, ТКП.',
  },
  {
    question: 'Какие сертификаты есть и как их получить?',
    answer: 'Полный список — в блоке «Сертификаты и документы» выше (PDF на скачивание). Дополнительные протоколы испытаний (режимы удержания температуры, ресурс циклов) — по запросу через форму. РУ Росздравнадзора нет — для лекарств с обязательным РУ рекомендуем профильных поставщиков.',
  },
];

/* ================================================================
   SCHEMA.ORG @graph: WebSite + BreadcrumbList + FAQPage.
   Organization добавляется автоматически из BaseLayout.
   ================================================================ */
const schema = [
  webSite({ siteUrl }),
  breadcrumbList([{ name: 'Главная', url: siteUrl }]),
  faqPage(faqs),
];
---

<BaseLayout
  title="Термоупаковка от производителя в РФ"
  description="Термопакеты, аккумуляторы холода SHOCK®, термосумки большие и термошопперы от завода в РФ. От 1 коробки. Брендирование от 100 шт. Расчёт за 2 часа."
  ogType="website"
  ogImage={`${siteUrl}assets/og/og-home.jpg`}
  schema={schema}
>
  <HeroLanding {...hero} />

  <ClientLogoBar />

  <TrustStrip
    eyebrow="Сертификаты и документы"
    heading="Сертификаты и документы — всё под рукой"
    items={trustItems}
  />

  <AdvantagesGrid
    eyebrow="О производстве"
    heading="Своё производство в Подмосковье"
    advantages={advantages}
    pills={pills}
    backgroundImage="/assets/splash/factory-bg.jpg"
  />

  <WarehouseImmersion
    eyebrow="Внутри производства"
    heading="Зайдите на склад вместе с нами"
    videoSrc="/media/warehouse-walk.mp4"
    videoSrcWebm="/media/warehouse-walk.webm"
    videoSrcMobile="/media/warehouse-walk-mobile.mp4"
    poster="/media/warehouse-poster.jpg"
    captions={[
      {
        from: 0,
        to: 0.34,
        eyebrow: '~2 000 м²',
        text: 'Производственная площадь в Подмосковье — собираем партии и держим запас.',
      },
      {
        from: 0.34,
        to: 0.67,
        eyebrow: '100 000+ шт на складе',
        text: 'Серийные позиции отгружаем за 24 ч — от 1 коробки до паллеты.',
      },
      {
        from: 0.67,
        to: 1,
        eyebrow: '1 млн ед/мес',
        text: 'Проектная мощность завода — конвейер не останавливается.',
      },
    ]}
  />

  <IndustryCardsGrid
    eyebrow="Решения по отраслям"
    heading="Решения для 5 отраслей"
    cards={industries}
    hubCta={{ label: 'Все решения по отраслям →', href: '/solutions/' }}
  />

  <InlineCtaRibbon />

  <CatalogShowcase
    eyebrow="Каталог продукции"
    heading="6 категорий, 58 SKU, от 49 ₽"
    categories={categories}
    products={products}
    hubCta={{ label: 'Весь каталог →', href: '/products/' }}
  />

  <JourneyTimeline
    eyebrow="От заявки до склада клиента"
    heading="Прозрачный процесс — 7 шагов"
    steps={journey}
    totalNote="Полный цикл: 14-21 день. Срочные партии — обсуждаем индивидуально."
  />

  <CaseCardsGrid
    eyebrow="Кейсы и доказательства"
    heading="Как клиенты решают тепло-холодовые задачи"
    cases={cases}
    hubCta={{ label: 'Все кейсы →', href: '/cases/' }}
  />

  <InlineCtaRibbon />

  <BrandingDuo
    eyebrow="Брендирование"
    heading="Упаковка и хладоэлементы с вашим логотипом"
    cards={brandingCards}
  />

  <WhitepaperCards />

  <FaqAccordion
    id="faq"
    eyebrow="Частые вопросы"
    heading="Что обычно спрашивают B2B-закупщики"
    items={faqs}
  />

  <InlineCtaRibbon />

  <FormBlock
    id="cta"
    variant="calculator"
    eyebrow="Калькулятор + связь с менеджером"
    heading="Подсчитать стоимость партии и связаться с менеджером"
    description="Заполните форму — менеджер вернётся с расчётом и рекомендованным комплектом за 2 часа в рабочее время (Пн-Пт 09:00-18:00 МСК). Параллельный канал — WhatsApp +7 (800) 101-15-25 или Telegram @termy_brand."
    submitLabel="Подсчитать и отправить →"
  />

  <PreFooterCta
    heading="Не хотите заполнять форму?"
    lead="Напишите в WhatsApp или позвоните — менеджер ответит сразу."
    primaryCta={{ label: 'Написать в WhatsApp', href: 'https://wa.me/78001011525' }}
    secondaryCta={{ label: 'Позвонить +7 (800) 101-15-25', href: 'tel:+78001011525' }}
  />

  <StickyWhatsApp />
</BaseLayout>

