---

<BaseLayout
  title="О компании — производитель термоупаковки"
  description="ООО «ТЕРМИ» — производство в Люберцах, ~1 млн ед/мес, 30–70 чел., более 5 лет на рынке. ISO 9001, ТР ТС 005/2011."
  ogType="website"
  ogImage={`${siteUrl}assets/og/og-about.jpg`}
  schema={schema}
>
  <Breadcrumbs
    items={[
      { name: 'Главная', href: '/' },
      { name: 'О компании' },
    ]}
  />

  <IndustryHero {...hero} />

  <TimelineCompany
    eyebrow="История"
    heading="История бренда TERMY"
    lead="Шесть точек на нашей траектории: от запуска бренда в 2020 до экспортных приоритетов 2026 года."
    items={milestones}
  />

  <section class="callouts" aria-labelledby="callouts-h2">
    <div class="container">
      <h2 id="callouts-h2" class="callouts__h2">Загляните глубже</h2>
      <ul class="callouts__grid" role="list">
        <li>
          <CardBase variant="feature">
            <h3 slot="title" class="callouts__title">Производство в Люберцах</h3>
            <p>2000 м², ~1 млн ед/мес, 3 стадии контроля качества. Видео и фото с производства.</p>
            <Button slot="cta" variant="secondary" size="base" href="/about/production/">Открыть страницу производства →</Button>
          </CardBase>
        </li>
        <li>
          <CardBase variant="feature">
            <h3 slot="title" class="callouts__title">8 преимуществ TERMY</h3>
            <p>Формат 42×50 PRO впервые в РФ, МОЗ от 1 коробки, бесплатный макет, патент-защищённый SHOCK®.</p>
            <Button slot="cta" variant="secondary" size="base" href="/about/advantages/">Открыть преимущества →</Button>
          </CardBase>
        </li>
      </ul>
    </div>
  </section>

  <DocumentsList
    eyebrow="Сертификаты"
    heading="Стандарты и документы"
    lead="Полный compliance-пакет для тендеров и аудита: ТР ТС, ГОСТ, ТУ, патент. Дополнительные документы — по запросу через форму."
    items={certificates}
  />

  <section class="clients" aria-labelledby="clients-h2">
    <div class="container">
      <p class="clients__eyebrow">Среди клиентов</p>
      <h2 id="clients-h2" class="clients__h2">Крупнейшие сервисы доставки и ритейл-сети России</h2>
      <p class="clients__lead">
        Мы работаем с крупнейшими сервисами доставки и ритейл-сетями. Имена клиентов
        раскрываем по запросу и при наличии письменного согласия — это часть нашей
        политики конфиденциальности.
      </p>
    </div>
  </section>

  <PreFooterCta
    heading="Готовы посчитать?"
    lead="Получите расчёт под вашу задачу или скачайте карточку предприятия для бухгалтерии."
    primaryCta={{ label: 'Получить расчёт →', href: '/contacts/#cta' }}
    secondaryCta={{ label: 'Скачать карточку предприятия PDF →', href: '/contacts/#docs' }}
  />

  <StickyWhatsApp />
</BaseLayout>

<style>
  .key-facts { padding-block: var(--spacing-7); background: var(--color-bg-surface-warm); }
  .key-facts__h2 { margin-block-end: var(--spacing-5); }
  .key-facts__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-3);
  }
  @media (min-width: 768px)  { .key-facts__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .key-facts__grid { grid-template-columns: repeat(4, 1fr); } }

  .callouts { padding-block: var(--spacing-8); }
  .callouts__h2 { margin-block-end: var(--spacing-5); }
  .callouts__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }
  @media (min-width: 768px) { .callouts__grid { grid-template-columns: repeat(2, 1fr); } }
  .callouts__title { margin: 0; font-size: var(--font-size-lg); font-weight: var(--font-weight-bold); }

  .clients { padding-block: var(--spacing-8); background: var(--color-bg-surface); }
  .clients__eyebrow {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--font-letter-spacing-widest);
    text-transform: uppercase;
    margin-block-end: var(--spacing-3);
  }
  .clients__h2 { max-width: 36ch; margin-block-end: var(--spacing-4); }
  .clients__lead { max-width: 60ch; color: var(--color-text-secondary); line-height: var(--font-line-height-normal); }
</style>
