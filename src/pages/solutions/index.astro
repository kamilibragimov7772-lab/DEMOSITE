---

<BaseLayout
  title="Решения для бизнеса — термоупаковка"
  description="Термоупаковка для 5 ниш: доставка, ритейл, дистрибуция, скоропорт, фарм-смежные. Найдите своё решение и получите расчёт за 2 часа."
  ogType="website"
  ogImage={`${siteUrl}assets/og/og-solutions.jpg`}
  schema={schema}
>
  <Breadcrumbs
    items={[
      { name: 'Главная', href: '/' },
      { name: 'Решения' },
    ]}
  />

  <section class="hub-hero" aria-labelledby="hub-hero-h1">
    <div class="container">
      <p class="hub-hero__eyebrow">{hero.eyebrow}</p>
      <h1 id="hub-hero-h1" class="hub-hero__h1">{hero.h1}</h1>
      <p class="hub-hero__lead">{hero.lead}</p>
    </div>
  </section>

  <IndustryCardsGrid
    eyebrow="5 отраслевых направлений"
    heading="Найдите решение под ваш сегмент"
    cards={industries}
  />

  <FaqAccordion
    id="faq-solutions"
    eyebrow="Частые вопросы"
    heading="Как выбрать решение под отрасль"
    items={faqs}
  />

  <FormBlock
    id="solutions-hub"
    variant="lead"
    eyebrow="Расчёт под отрасль"
    heading="Получить расчёт для вашей отрасли"
    description="Заполните форму и укажите вашу отрасль в комментарии. Менеджер свяжется в течение 2 часов и подберёт комплект под груз, маршрут и тираж."
    submitLabel="Получить расчёт →"
  />

  <PreFooterCta
    heading="Не хотите заполнять форму?"
    lead="Напишите в WhatsApp или позвоните — менеджер ответит сразу."
    primaryCta={{ label: 'Написать в WhatsApp', href: 'https://wa.me/78001011525' }}
    secondaryCta={{ label: 'Позвонить +7 (800) 101-15-25', href: 'tel:+78001011525' }}
  />

  <StickyWhatsApp />
</BaseLayout>

<style>
  .hub-hero {
    padding-block: var(--spacing-7) var(--spacing-6);
    background: var(--color-bg-page);
  }
  .hub-hero__eyebrow {
    color: var(--color-action-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--font-letter-spacing-widest);
    text-transform: uppercase;
    margin-block-end: var(--spacing-3);
  }
  .hub-hero__h1 {
    max-width: 24ch;
    font-size: var(--font-size-h1-fluid);
    font-weight: var(--font-weight-bold);
    line-height: var(--font-line-height-tight);
    letter-spacing: var(--font-letter-spacing-tighter);
    margin-block-end: var(--spacing-4);
  }
  .hub-hero__lead {
    max-width: 56ch;
    color: var(--color-text-secondary);
    font-size: var(--font-size-md);
    line-height: var(--font-line-height-normal);
  }
</style>
