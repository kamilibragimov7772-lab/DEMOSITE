  />

  <CaseHighlight
    eyebrow="Кейс — расчётный пример"
    heading="Мясокомбинат: 300+ км при 0…−15°C летом"
    segmentLabel="Производство скоропорта"
    title="Удержание режима подтверждено температурным регистратором"
    story={caseStory}
    metrics={caseMetrics}
    isCalculatedExample={true}
