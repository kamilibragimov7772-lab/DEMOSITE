    hubCta={{ label: 'Все продукты в каталоге →', href: '/products/' }}
  />

  <CaseHighlight
    eyebrow="Кейс — расчётный пример"
    heading="Премиум FMCG: 4-цветная шелкография 500 шт за 3 недели"
    segmentLabel="Крупный ритейл"
    title="СТМ запущена в категорийную ротацию"
    story={caseStory}
    metrics={caseMetrics}
    isCalculatedExample={true}
  />

  <DocumentsList
    eyebrow="Тендерные документы"
    heading="Документы для службы безопасности и бухгалтерии"
    lead="Compliance-пакет для тендеров federal-сетей: ТР ТС, ISO 9001, ТУ, карточка предприятия."
    items={documents}
  />

  <FormBlock
    id="cta"
    variant="lead"
    eyebrow="Расчёт под ассортимент"
    heading="Получить расчёт для вашего ритейла"
