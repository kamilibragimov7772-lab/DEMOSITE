  <IndustryHero {...hero} />

  <PainPointsList
    eyebrow="Боли категорийного закупщика"
    heading="Что блокирует категорийную ротацию"
    items={painPoints}
  />

  <MethodsGrid
    eyebrow="СТМ — методы брендирования"
    heading="4 метода печати под закупочные требования сетей"
    methods={methods}
  />

  <ProductTriad
    eyebrow="Рекомендованный комплект"
    heading="Что мы предлагаем ритейлу"
    lead="Брендирование под СТМ + узнаваемый SHOCK в витрине = категория работает на оборот, а не лежит."
