  <IndustryHero {...hero} />

  <PainPointsList
    eyebrow="Боли коммерческого директора"
    heading="Что мешает дистрибуции расти"
    items={painPoints}
  />

  <ProductTriad
    eyebrow="Рекомендованная линейка"
    heading="6 категорий, которые работают для дистрибуции"
    lead="Полная линейка под перепродажу: бестселлеры + premium-ниша + низкий порог входа. Резерв 100 000 шт постоянно на складе."
