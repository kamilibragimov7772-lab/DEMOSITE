  />

  <CaseHighlight
    eyebrow="Кейс — расчётный пример"
    heading="Региональный дистрибьютор: рост оборота +30% за сезон"
    segmentLabel="Дистрибьюция"
    title="Резерв TERMY как страховка от сезонной просадки"
    story={caseStory}
    metrics={caseMetrics}
    isCalculatedExample={true}
  />

  <DocumentsList
    eyebrow="Документы и условия"
    heading="Документы для подключения дистрибьютора"
    lead="ЭДО — за 1 неделю. Условия оплаты — постфактум 30 дней для проверенных партнёров. Полный прайс — на email через форму."
    items={documents}
  />

  <FormBlock
    id="cta"
    variant="lead"
    eyebrow="Расчёт оптовой цены"
    heading="Получить прайс дистрибьютора"
    description="РОП дистрибьюторов свяжется в течение 1 часа, оценит ваш регион и согласует спеццены. Укажите регион / город в комментарии."
