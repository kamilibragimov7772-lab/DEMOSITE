---
/**
 * FormField — molecule.
 * Composition: Label + Input + Helper-text + Error-message.
 *
 * Связывает <label for> + <input id> + helper / error через aria-describedby.
 * Источник: 03_design_system/components_atomic.md §Molecules (Form field).
 */

import Input from '@components/atoms/Input.astro';

type InputType = 'text' | 'email' | 'tel' | 'number' | 'url' | 'search' | 'password' | 'textarea' | 'select';

export interface Props {
  id: string;
  name: string;
  label: string;
  type?: InputType;
  value?: string | number;
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  readonly?: boolean;
  autocomplete?: string;
  inputmode?: 'text' | 'numeric' | 'decimal' | 'tel' | 'email' | 'url' | 'search';
  pattern?: string;
  minlength?: number;
  maxlength?: number;
  rows?: number;
  helper?: string;
  error?: string;
  size?: 'sm' | 'base';
  options?: ReadonlyArray<{ value: string; label: string }>;
  class?: string;
}

const {
  id,
  name,
  label,
  type = 'text',
  value,
  placeholder,
  required = false,
  disabled = false,
  readonly = false,
  autocomplete,
  inputmode,
  pattern,
  minlength,
  maxlength,
  rows,
  helper,
  error,
  size = 'base',
  options,
  class: className,
} = Astro.props;

const helperId = helper ? `${id}-helper` : undefined;
const errorId = error ? `${id}-error` : undefined;
const describedBy = [helperId, errorId].filter(Boolean).join(' ') || undefined;
const invalid = Boolean(error);
---

<div class={`form-field${className ? ' ' + className : ''}`}>
  <label class="form-field__label" for={id}>
    {label}
    {required && <span class="form-field__required" aria-hidden="true">*</span>}
    {required && <span class="sr-only">— обязательное поле</span>}
  </label>

  <Input
    id={id}
    name={name}
    type={type}
    value={value}
    placeholder={placeholder}
    required={required}
    disabled={disabled}
    readonly={readonly}
    autocomplete={autocomplete}
    inputmode={inputmode}
    pattern={pattern}
    minlength={minlength}
    maxlength={maxlength}
    rows={rows}
    invalid={invalid}
    describedBy={describedBy}
    size={size}
    options={options}
  />

  {helper && !error && (
    <p id={helperId} class="form-field__helper">{helper}</p>
  )}

  {error && (
    <p id={errorId} class="form-field__error" role="alert">
      {error}
    </p>
  )}
</div>

<style>
  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .form-field__label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-primary);
    line-height: 1.4;
  }

  .form-field__required {
    color: var(--color-feedback-error);
    margin-inline-start: var(--spacing-1);
  }

  .form-field__helper {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.45;
  }

  .form-field__error {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-feedback-error);
    line-height: 1.45;
  }
</style>
