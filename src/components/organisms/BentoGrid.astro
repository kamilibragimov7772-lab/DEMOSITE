---
/**
 * BentoGrid — organism (V4-1, iter4 visual-b2b-audit-loop).
 *
 * Bento-layout 2026: 1 large card (60% ширины) + N small (правая колонка).
 * Заменяет equal-grid в hub-страницах (about, advantages) для современной асимметрии.
 *
 * Анти-AI 2026 trend: gradient-tint на large + Lucide-иконки + опц. metric-цифра.
 *
 * Tokens-only. Поддерживает prefers-reduced-motion и focus-visible (global).
 */

export interface BentoCard {
  title: string;
  description?: string;
  href?: string;
  size?: 'large' | 'small';
  /** Lucide path-d (без обрамляющего <svg>) */
  iconSvg?: string;
  /** Крупная цифра, опц. (например «2 000») */
  metric?: string;
  metricLabel?: string;
}

export interface Props {
  eyebrow?: string;
  heading: string;
  /** Первая карта = large, остальные small. */
  cards: BentoCard[];
}

const { eyebrow, heading, cards } = Astro.props;
---

<section class="bento" aria-labelledby="bento-h">
  <div class="container">
    {eyebrow && <p class="bento__eyebrow">{eyebrow}</p>}
    <h2 id="bento-h" class="bento__heading">{heading}</h2>
    <div class="bento__grid">
      {cards.map((c, i) => (
        <a
          class={`bento__card ${i === 0 ? 'bento__card--large' : 'bento__card--small'}`}
          href={c.href ?? '#'}
        >
          {c.iconSvg && (
            <svg
              class="bento__icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <Fragment set:html={c.iconSvg} />
            </svg>
          )}
          {c.metric && (
            <p class="bento__metric">
              <strong>{c.metric}</strong>
              {c.metricLabel && <span>{c.metricLabel}</span>}
            </p>
          )}
          <h3 class="bento__title">{c.title}</h3>
          {c.description && <p class="bento__desc">{c.description}</p>}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .bento {
    padding-block: var(--spacing-7);
    background: var(--color-bg-page);
  }

  .bento__eyebrow {
    color: var(--color-action-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--font-letter-spacing-widest);
    text-transform: uppercase;
    margin: 0 0 var(--spacing-3);
  }

  .bento__heading {
    font-size: var(--font-size-h2-fluid);
    margin: 0 0 var(--spacing-6);
    max-width: 28ch;
  }

  .bento__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }

  .bento__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    padding: var(--spacing-5);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle, var(--color-border-default));
    border-radius: var(--radius-lg, 16px);
    text-decoration: none;
    color: var(--color-text-primary);
    transition:
      border-color var(--duration-fast) var(--easing-standard),
      box-shadow var(--duration-fast) var(--easing-standard),
      transform var(--duration-fast) var(--easing-standard);
    overflow: hidden;
  }

  .bento__card:hover {
    border-color: var(--color-action-primary);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-action-primary) 12%, transparent);
    transform: translateY(-2px);
  }

  .bento__card--large {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-action-primary) 8%, var(--color-bg-surface)),
      var(--color-bg-surface)
    );
    min-height: 320px;
  }

  .bento__icon {
    width: 28px;
    height: 28px;
    color: var(--color-action-primary);
    flex-shrink: 0;
  }
  .bento__card--large .bento__icon {
    width: 40px;
    height: 40px;
  }

  .bento__metric {
    margin: 0;
    line-height: 1;
  }
  .bento__metric strong {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-action-primary);
    font-family: var(--font-family-monospace, 'JetBrains Mono', monospace);
    line-height: 1;
    display: block;
    font-feature-settings: 'tnum';
  }
  .bento__metric span {
    display: block;
    margin-top: var(--spacing-1);
    font-size: var(--font-size-xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: var(--font-letter-spacing-widest);
  }

  .bento__title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    margin: 0;
  }
  .bento__card--large .bento__title {
    font-size: var(--font-size-xl);
  }

  .bento__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .bento__grid {
      grid-template-columns: 2fr 1fr;
      grid-template-rows: repeat(3, auto);
    }
    .bento__card--large {
      grid-column: 1 / 2;
      grid-row: 1 / 4;
    }
  }

  .bento__card:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .bento__card {
      transition: none;
    }
    .bento__card:hover {
      transform: none;
    }
  }
</style>
