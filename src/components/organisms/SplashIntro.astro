---
/**
 * SplashIntro — overlay-заставка при первом заходе на сайт.
 *
 * Фон: фотография цеха `public/assets/splash/factory-bg.jpg` + тёмный overlay (65%).
 * Текст «TERMY» появляется в стиле ВЕРТИКАЛЬНЫХ ЖАЛЮЗИ (Venetian blinds):
 *   8 вертикальных полосок, каждая — копия текста с clip-path к своей зоне,
 *   transform-origin в центре своей полоски, scaleX(0) → scaleX(1) с stagger 70ms.
 * После того как все полоски «открылись» — fade-in звёздочки и meta-подписи.
 *
 * Поведение:
 *   - Показывается только 1 раз за сессию (sessionStorage flag).
 *   - Длительность: ~2100ms (вход 200 + blinds 1120 + hold 380 + fade-out 400).
 *   - prefers-reduced-motion → выключается полностью (skip).
 *   - Если JS отключён — overlay не показывается (рендерится скрытым).
 *
 * NB: для production картинку положить в public/assets/splash/factory-bg.jpg
 *     (1920×1080 рекомендую, JPG, до 300 KB после сжатия).
 *     Если файла нет — fallback на сплошной brand-purple фон.
 */

const BLINDS = 8;
const blindIndexes = Array.from({ length: BLINDS }, (_, i) => i);
---

<div class="splash" data-splash aria-hidden="true">
  <div class="splash__bg" aria-hidden="true"></div>
  <div class="splash__overlay" aria-hidden="true"></div>

  <div class="splash__logo">
    <span class="splash__name" aria-label="TERMY">
      {/* sizer держит размеры — невидимый текст для расчёта ширины контейнера */}
      <span class="splash__name__sizer" aria-hidden="true">TERMY</span>
      {/* 8 vertical blinds — каждая показывает только свою вертикальную полоску текста через clip-path */}
      {blindIndexes.map((i) => {
        const left = i * (100 / BLINDS);
        const right = (BLINDS - 1 - i) * (100 / BLINDS);
        const centerX = left + (100 / BLINDS) / 2;
        return (
          <span
            class="splash__name__blind"
            aria-hidden="true"
            style={`--i: ${i}; clip-path: inset(0 ${right}% 0 ${left}%); transform-origin: ${centerX}% center;`}
          >TERMY</span>
        );
      })}
    </span>
    <span class="splash__star" aria-hidden="true">
      <svg viewBox="-50 -50 100 100" xmlns="http://www.w3.org/2000/svg">
        <g fill="currentColor">
          <rect x="-7" y="-44" width="14" height="88" rx="3"/>
          <rect x="-7" y="-44" width="14" height="88" rx="3" transform="rotate(60)"/>
          <rect x="-7" y="-44" width="14" height="88" rx="3" transform="rotate(120)"/>
        </g>
      </svg>
    </span>
  </div>
  <p class="splash__meta">производитель термоупаковки · с 2008</p>
</div>

<script is:inline>
(() => {
  const splash = document.querySelector('[data-splash]');
  if (!splash) return;

  /* Не показываем, если уже видели в этой сессии или reduced-motion. */
  const seen = sessionStorage.getItem('termy-splash-seen');
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (seen || reduceMotion) {
    splash.style.display = 'none';
    return;
  }

  sessionStorage.setItem('termy-splash-seen', '1');

  /* Блокируем скролл на время заставки. */
  document.documentElement.style.overflow = 'hidden';

  /* Запускаем анимацию входа. */
  splash.classList.add('is-visible');

  /* Через 1700ms — fade-out (после того как blinds + star + meta показались). */
  setTimeout(() => {
    splash.classList.add('is-leaving');
  }, 1700);

  /* Через 2100ms — убираем элемент полностью. */
  setTimeout(() => {
    splash.remove();
    document.documentElement.style.overflow = '';
  }, 2100);
})();
</script>

<style>
  .splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-3, 12px);
    /* Fallback цвет — brand-purple (если фото 404). */
    background: var(--color-action-primary, #6428A0);
    pointer-events: auto;
    opacity: 0;
    transition: opacity 400ms cubic-bezier(0.4, 0, 0.2, 1);
    isolation: isolate;
  }
  .splash.is-visible {
    display: flex;
    animation: splash-fade-in 200ms cubic-bezier(0, 0, 0.2, 1) forwards;
  }
  .splash.is-leaving {
    opacity: 0;
    pointer-events: none;
  }
  @keyframes splash-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ─── Фон: фото цеха + тёмный overlay для читаемости текста ───────── */
  .splash__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background: url('/assets/splash/factory-bg.jpg') center / cover no-repeat;
    /* Лёгкое масштабирование для cinematic-эффекта */
    transform: scale(1.04);
    animation: splash-bg-zoom 4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes splash-bg-zoom {
    from { transform: scale(1.04); }
    to   { transform: scale(1.0);  }
  }

  .splash__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      135deg,
      rgba(10, 6, 24, 0.72) 0%,
      rgba(20, 14, 38, 0.62) 50%,
      rgba(40, 18, 70, 0.62) 100%
    );
  }

  /* ─── Логотип контейнер ─────────────────────────────────────────────── */
  .splash__logo {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    transform: translateY(8px);
    opacity: 1; /* контейнер виден, blinds внутри сами анимируются */
  }

  /* ─── TERMY с venetian-blinds эффектом ─────────────────────────────── */
  .splash__name {
    position: relative;
    display: inline-block;
    font-family: var(--font-family-sans, 'Inter', sans-serif);
    font-size: clamp(64px, 11vw, 140px);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: #ffffff;
    white-space: nowrap;
    line-height: 1;
  }
  /* Sizer — невидимый, держит ширину контейнера. */
  .splash__name__sizer {
    visibility: hidden;
  }
  /* Blinds — 8 копий «TERMY» поверх sizer, каждая clip-pathed к своей вертикальной зоне. */
  .splash__name__blind {
    position: absolute;
    inset: 0;
    display: block;
    color: #ffffff;
    transform: scaleX(0);
    /* transform-origin переопределяется inline для каждой полоски (центр своей strip). */
    animation: splash-blind-open 540ms cubic-bezier(0.2, 0.9, 0.25, 1) forwards;
    animation-delay: calc(var(--i, 0) * 70ms + 200ms);
    /* edge-сглаживание чтобы стыки полос не были видны */
    backface-visibility: hidden;
    will-change: transform;
  }
  @keyframes splash-blind-open {
    to { transform: scaleX(1); }
  }

  /* ─── Звёздочка — fade-in после blinds, потом infinite spin ────────── */
  .splash__star {
    display: inline-block;
    width: 0.32em;
    height: 0.32em;
    color: var(--color-action-primary, #6428A0);
    /* Чуть осветляем для contrast на тёмном overlay */
    filter: brightness(1.4) saturate(1.1);
    font-size: clamp(64px, 11vw, 140px);
    margin-inline-start: 0.08em;
    vertical-align: top;
    line-height: 1;
    transform: translateY(0.04em) scale(0);
    animation: splash-star-pop 500ms cubic-bezier(0.34, 1.4, 0.35, 1) 1100ms forwards;
  }
  @keyframes splash-star-pop {
    to { transform: translateY(0.04em) scale(1); }
  }
  .splash__star svg {
    width: 100%;
    height: 100%;
    display: block;
    transform-origin: 50% 50%;
    animation: splash-star-spin 1.4s linear 1300ms infinite;
    will-change: transform;
  }
  @keyframes splash-star-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ─── Метатекст ────────────────────────────────────────────────────── */
  .splash__meta {
    font-family: var(--font-family-monospace, 'JetBrains Mono', monospace);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
    opacity: 0;
    margin: 0;
    animation: splash-meta-in 500ms cubic-bezier(0.16, 1, 0.3, 1) 1300ms forwards;
  }
  @keyframes splash-meta-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0);   }
  }

  /* ─── Reduced motion — splash полностью отключён через JS, но на всякий случай ── */
  @media (prefers-reduced-motion: reduce) {
    .splash,
    .splash__logo,
    .splash__name__blind,
    .splash__star,
    .splash__meta,
    .splash__bg {
      display: none !important;
      animation: none !important;
    }
  }
</style>
