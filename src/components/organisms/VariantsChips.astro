---
/**
 * VariantsChips — organism.
 * Горизонтальная полоса вариантов выбора (размер / объём / цвет / режим / серия).
 * Каждый chip — anchor-link на другой PDP (или anchor #variant-X).
 *
 * Семантика: <fieldset><legend> + <ul role="list"> для группировки родственных вариантов.
 * Активный вариант — `aria-current="page"`, без href (текущий SKU).
 *
 * Состояния (per components_atomic):
 *   - default / hover / focus-visible / active (current SKU) / disabled (sold-out / not-available)
 *
 * Motion:
 *   - hover: border-color + bg `fast` `standard`
 *   - reduced-motion → instant
 *
 * Источник:
 *   - 04_visuals/15-pdp-template.spec.md §«Block: Hero — PDP»
 *   - 02_content/page_outlines/15a-product-card-variants.md (Блок 8 Dimensions matrix)
 *   - components_atomic.md §Atoms (Chip)
 */

export interface VariantOption {
  /** Лейбл (e.g. «42×50 см» / «450 мл» / «Жёлтый»). */
  label: string;
  /** href на соседний PDP (если null — current). */
  href?: string;
  /** disabled — sold-out / not-available. */
  disabled?: boolean;
  /** Опц. вторичная подпись («МОЗ 1 000 шт»). */
  meta?: string;
}

export interface VariantGroup {
  /** Заголовок группы вариантов (legend). */
  legend: string;
  /** Slug группы — для уникальности id. */
  slug: string;
  /** Опции (3-12 chip'ов). */
  options: ReadonlyArray<VariantOption>;
}

export interface Props {
  /** 1-3 группы вариантов (размеры / цвета / режимы). */
  groups: ReadonlyArray<VariantGroup>;
}

const { groups } = Astro.props;
---

<section class="vchips" aria-label="Варианты товара">
  {groups.map((group) => (
    <fieldset class="vchips__group">
      <legend class="vchips__legend">{group.legend}</legend>
      <ul class="vchips__list" role="list">
        {group.options.map((opt) => {
          const isCurrent = !opt.href && !opt.disabled;
          const isLink = !!opt.href && !opt.disabled;
          return (
            <li>
              {isLink ? (
                <a
                  class="vchips__chip"
                  href={opt.href}
                  aria-label={opt.meta ? `${opt.label} — ${opt.meta}` : opt.label}
                >
                  <span class="vchips__chip-label">{opt.label}</span>
                  {opt.meta && <span class="vchips__chip-meta">{opt.meta}</span>}
                </a>
              ) : (
                <span
                  class:list={[
                    'vchips__chip',
                    isCurrent && 'vchips__chip--current',
                    opt.disabled && 'vchips__chip--disabled',
                  ]}
                  aria-current={isCurrent ? 'page' : undefined}
                  aria-disabled={opt.disabled || undefined}
                >
                  <span class="vchips__chip-label">{opt.label}</span>
                  {opt.meta && <span class="vchips__chip-meta">{opt.meta}</span>}
                </span>
              )}
            </li>
          );
        })}
      </ul>
    </fieldset>
  ))}
</section>

<style>
  .vchips {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .vchips__group {
    margin: 0;
    padding: 0;
    border: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }
  .vchips__legend {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--font-letter-spacing-widest);
    text-transform: uppercase;
    padding: 0;
  }

  .vchips__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .vchips__chip {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    min-height: 44px;
    padding: var(--spacing-2) var(--spacing-3);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-base);
    background: var(--color-bg-page);
    color: var(--color-text-primary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    line-height: 1.2;
    text-decoration: none;
    transition:
      border-color var(--duration-fast) var(--easing-standard),
      background-color var(--duration-fast) var(--easing-standard),
      color var(--duration-fast) var(--easing-standard);
  }
  .vchips__chip-label { white-space: nowrap; }
  .vchips__chip-meta {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-regular);
  }

  /* hover/focus только на интерактивных (a) */
  a.vchips__chip:hover,
  a.vchips__chip:focus-visible {
    border-color: var(--color-action-primary);
    color: var(--color-action-primary);
  }

  .vchips__chip--current {
    border-color: var(--color-action-primary);
    background: var(--color-action-primary);
    color: var(--color-text-on-brand);
    box-shadow: 0 0 0 1px var(--color-action-primary);
  }
  .vchips__chip--current .vchips__chip-meta {
    color: var(--color-text-on-brand);
    opacity: 0.85;
  }

  .vchips__chip--disabled {
    border-style: dashed;
    color: var(--color-text-tertiary);
    background: var(--color-bg-surface);
    cursor: not-allowed;
  }
  .vchips__chip--disabled .vchips__chip-label {
    text-decoration: line-through;
  }

  @media (prefers-reduced-motion: reduce) {
    .vchips__chip { transition: none; }
  }
</style>
