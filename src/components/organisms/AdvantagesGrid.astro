---
/**
 * AdvantagesGrid — organism.
 * Composition: H2 + 4 крупных advantage-плитки + 8 пилюль (chips, фактоиды).
 *
 * Источник:
 * - 04_visuals/01-homepage.spec.md §«Block 4: УТП "Больше, чем производитель"»
 * - 02_content/page_outlines/01-homepage.md §«H2: Больше, чем производитель»
 */

import Chip from '@components/molecules/Chip.astro';

export interface Advantage {
  title: string;
  description: string;
  /** Optional SVG icon markup (24×24 viewBox). */
  icon?: string;
}

export interface Props {
  heading: string;
  /** 4 главных преимущества. */
  advantages: ReadonlyArray<Advantage>;
  /** ≤12 фактоидов-пилюль (factoids). Из outline'а — 8 шт. */
  pills: ReadonlyArray<string>;
  eyebrow?: string;
  /** Optional background image path — применяется как subtle texture. */
  backgroundImage?: string;
}

const { heading, advantages, pills, eyebrow, backgroundImage } = Astro.props;
---

<section class="adv" aria-labelledby="adv-h2" style={backgroundImage ? `--adv-bg: url('${backgroundImage}')` : undefined}>
  <div class="container">
    {eyebrow && <p class="adv__eyebrow">{eyebrow}</p>}
    <h2 id="adv-h2" class="adv__h2">{heading}</h2>

    <ul class="adv__grid" role="list">
      {advantages.map((a) => (
        <li class="adv__item">
          {a.icon && (
            <span class="adv__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={a.icon} />
            </span>
          )}
          <h3 class="adv__title">{a.title}</h3>
          <p class="adv__desc">{a.description}</p>
        </li>
      ))}
    </ul>

    <ul class="adv__pills" role="list" aria-label="Ключевые факты о компании">
      {pills.map((p) => (
        <li><Chip variant="default" size="base">{p}</Chip></li>
      ))}
    </ul>
  </div>
</section>

<style>
  .adv {
    padding-block: var(--spacing-8);
    position: relative;
    isolation: isolate;
  }
  .adv[style*="--adv-bg"]::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--adv-bg);
    background-size: cover;
    background-position: center;
    opacity: 0.06;
    z-index: -1;
  }
  .adv__eyebrow {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--font-letter-spacing-widest);
    text-transform: uppercase;
    margin-block-end: var(--spacing-3);
  }
  .adv__h2 {
    max-width: 32ch;
    margin-block-end: var(--spacing-6);
  }

  .adv__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
    margin: 0 0 var(--spacing-6);
    padding: 0;
    list-style: none;
  }
  .adv__item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    padding: var(--spacing-5);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-base);
    transition: border-color var(--duration-fast) var(--easing-standard),
                box-shadow var(--duration-fast) var(--easing-standard);
  }
  .adv__item:hover {
    border-color: var(--color-action-primary);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-action-primary) 30%, transparent);
  }
  .adv__icon {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-action-primary) 10%, var(--color-bg-page));
    color: var(--color-action-primary);
    flex-shrink: 0;
    margin-block-end: var(--spacing-1);
  }
  .adv__icon svg { width: 22px; height: 22px; display: block; }
  .adv__title {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }
  .adv__desc {
    color: var(--color-text-secondary);
    line-height: var(--font-line-height-normal);
  }

  .adv__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media (min-width: 768px) {
    .adv__grid { grid-template-columns: repeat(2, 1fr); gap: var(--spacing-5); }
  }
  @media (min-width: 1024px) {
    .adv__grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
