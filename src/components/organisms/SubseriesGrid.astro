---
/**
 * SubseriesGrid — organism.
 * Сетка карточек подсерий / температурных режимов / размеров категории.
 * Each card: eyebrow (опц.) + title + count/spec + description + sub-CTA («Открыть подсерию →»).
 *
 * Используется на:
 *   - /products/termopakety/  → 6 подсерий (Standart, Light, PRO, С дном, С клапаном, Zip-Lock)
 *   - /products/akkumulyatory-holoda/ → 3 режима (Cool / Gel / Freeze)
 *   - /products/termoshoppery/ → 5 размеров
 *
 * Источник:
 * - 04_visuals/09-catalog-termopakety.spec.md §«Размерный ряд»
 * - 02_content/page_outlines/09-catalog-termopakety.md §«H2: Подсерии»
 * - components_atomic.md §Organisms (Cards-grid)
 */

import CardBase from '@components/molecules/CardBase.astro';

export interface Subseries {
  /** Slug для URL: /products/<cat>/<slug>/ (Wave 2) или anchor #slug. */
  slug: string;
  /** Опциональная eyebrow (е.г. «PRO», «Cool»). */
  eyebrow?: string;
  /** Заголовок карточки. */
  title: string;
  /** Спецификация / cnt («8 SKU, 32×35 — 60×55 см»). */
  spec: string;
  /** Описание / use-case (1-2 строки). */
  description: string;
  /** href (либо относительный URL, либо anchor). */
  href: string;
  /** Текст CTA. По умолчанию «Открыть подсерию →». */
  ctaLabel?: string;
}

export interface Props {
  heading: string;
  eyebrow?: string;
  /** Lead-абзац (опц.). */
  lead?: string;
  items: ReadonlyArray<Subseries>;
  /** id для anchor-link. */
  id?: string;
}

const { heading, eyebrow, lead, items, id = 'subseries' } = Astro.props;
---

<section class="subg" id={id} aria-labelledby={`${id}-h2`}>
  <div class="container">
    {eyebrow && <p class="subg__eyebrow">{eyebrow}</p>}
    <h2 id={`${id}-h2`} class="subg__h2">{heading}</h2>
    {lead && <p class="subg__lead">{lead}</p>}

    <ul class="subg__grid" role="list">
      {items.map((s) => (
        <li>
          <CardBase href={s.href}>
            {s.eyebrow && <span slot="eyebrow" class="subg__card-eyebrow">{s.eyebrow}</span>}
            <h3 slot="title" class="subg__card-title">{s.title}</h3>
            <p slot="meta" class="subg__card-spec num">{s.spec}</p>
            <p class="subg__card-desc">{s.description}</p>
            <span slot="cta" class="subg__cta-label">{s.ctaLabel ?? 'Открыть подсерию →'}</span>
          </CardBase>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .subg {
    padding-block: var(--spacing-7);
    background: var(--color-bg-page);
  }
  .subg__eyebrow {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--font-letter-spacing-widest);
    text-transform: uppercase;
    margin-block-end: var(--spacing-3);
  }
  .subg__h2 {
    max-width: 32ch;
    margin-block-end: var(--spacing-3);
  }
  .subg__lead {
    max-width: 56ch;
    color: var(--color-text-secondary);
    margin-block-end: var(--spacing-5);
    line-height: var(--font-line-height-normal);
  }

  .subg__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .subg__card-eyebrow {
    display: inline-block;
    padding: 2px 8px;
    background: var(--color-bg-surface-warm);
    color: var(--color-action-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--font-letter-spacing-wide);
    text-transform: uppercase;
    border-radius: var(--radius-pill);
  }
  .subg__card-title {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
    line-height: var(--font-line-height-snug);
  }
  .subg__card-spec {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-sm);
    font-family: var(--font-family-monospace);
  }
  .subg__card-desc {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: var(--font-line-height-normal);
  }
  .subg__cta-label {
    margin-block-start: var(--spacing-3);
    color: var(--color-action-primary);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-sm);
  }

  @media (min-width: 768px) {
    .subg__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .subg__grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
