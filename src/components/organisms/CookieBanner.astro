---
/**
 * CookieBanner — organism.
 *
 * 152-ФЗ + GDPR-совместимый cookie consent banner.
 * Показывается при первом визите (если в localStorage нет `termy.cookies.v1`).
 * Три категории: necessary (always-on), analytics (Yandex Metrica), marketing (Yandex Direct + Bitrix24 chat).
 *
 * Persistence:
 * - localStorage: `termy.cookies.v1` = JSON {necessary,analytics,marketing,ts,v}
 * - cookie:        `termy_cookie_choice=...; max-age=31536000; path=/; samesite=lax` (1 год)
 *
 * События:
 * - `window.dispatchEvent(new CustomEvent('termy:cookies-updated', { detail }))` — для подключения Yandex Metrica/Direct по согласию.
 *
 * Источники:
 * - 04_visuals/22-legal-cookies.spec.md
 * - 02_content/page_outlines/22-legal-cookies.md (3 категории)
 * - 152-ФЗ ст. 9 (явное согласие)
 * - phase 7 iter2 — closes Security HIGH #1 (cookie consent runtime отсутствует)
 *
 * CSP: inline <script> без external dependencies. nonce-friendly: можно добавить позднее.
 */

---

<aside
  id="cookie-banner"
  class="cookie-banner"
  role="region"
  aria-label="Согласие на использование cookies"
  aria-live="polite"
  hidden
>
  <div class="cookie-banner__inner">
    {/* V4-4 (iter4): «Настроить» теперь раскрывает реальный modal с 3 категориями. */}
    <div class="cookie-banner__main">
      <p class="cookie-banner__text">
        Мы используем cookies для аналитики и маркетинга.
        <a href="/legal/cookies/">Подробнее в политике конфиденциальности.</a>
      </p>

      <div class="cookie-banner__actions">
        <button type="button" class="cookie-banner__btn cookie-banner__btn--primary" data-cookie-action="accept-all">
          Принять
        </button>
        <button type="button" class="cookie-banner__btn cookie-banner__btn--ghost" data-cookie-action="toggle-settings" aria-expanded="false" aria-controls="cookie-settings">
          Настроить
        </button>
        <button type="button" class="cookie-banner__btn cookie-banner__btn--ghost" data-cookie-action="reject">
          Отклонить
        </button>
      </div>
    </div>

    <div class="cookie-banner__settings" id="cookie-settings" data-cookie-settings hidden>
      <p class="cookie-banner__settings-title">Категории cookies</p>
      <ul class="cookie-cats" role="list">
        <li class="cookie-cat">
          <label class="cookie-cat__label">
            <input type="checkbox" data-cat="necessary" checked disabled />
            <span class="cookie-cat__name">Необходимые</span>
            <span class="cookie-cat__desc">CSRF-токены, сессия. Всегда включены — без них сайт не работает.</span>
          </label>
        </li>
        <li class="cookie-cat">
          <label class="cookie-cat__label">
            <input type="checkbox" data-cat="analytics" />
            <span class="cookie-cat__name">Аналитика</span>
            <span class="cookie-cat__desc">Yandex Metrica — анонимная статистика посещений, помогает улучшать сайт.</span>
          </label>
        </li>
        <li class="cookie-cat">
          <label class="cookie-cat__label">
            <input type="checkbox" data-cat="marketing" />
            <span class="cookie-cat__name">Маркетинг</span>
            <span class="cookie-cat__desc">Yandex Direct + Bitrix24 chat — ретаргетинг и онлайн-консультант.</span>
          </label>
        </li>
      </ul>
      <div class="cookie-banner__settings-actions">
        <button type="button" class="cookie-banner__btn cookie-banner__btn--primary" data-cookie-action="save">
          Сохранить выбор
        </button>
      </div>
    </div>
  </div>
</aside>

<script is:inline>
  (function () {
    'use strict';

    var STORAGE_KEY = 'termy.cookies.v1';
    var COOKIE_KEY = 'termy_cookie_choice';
    var COOKIE_MAX_AGE = 60 * 60 * 24 * 365; // 1 год
    var SCHEMA_VERSION = 1;

    var banner = document.getElementById('cookie-banner');
    if (!banner) return;

    function readChoice() {
      try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (!parsed || parsed.v !== SCHEMA_VERSION) return null;
        return parsed;
      } catch (e) {
        return null;
      }
    }

    function writeChoice(choice) {
      var record = {
        v: SCHEMA_VERSION,
        ts: Date.now(),
        necessary: true,
        analytics: !!choice.analytics,
        marketing: !!choice.marketing,
      };
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(record));
      } catch (e) { /* localStorage заблокирован — fallback на cookie */ }
      // Дублируем в cookie на 1 год — чтобы на серверной стороне (Vercel/CF Edge) можно было прочитать.
      var cookieValue = encodeURIComponent(JSON.stringify(record));
      document.cookie = COOKIE_KEY + '=' + cookieValue + '; max-age=' + COOKIE_MAX_AGE + '; path=/; samesite=lax';

      // Сигнал внешним скриптам (Yandex Metrica/Direct/Bitrix24) — подключаться по согласию.
      try {
        window.dispatchEvent(new CustomEvent('termy:cookies-updated', { detail: record }));
      } catch (e) { /* CustomEvent unsupported — игнор */ }

      hideBanner();
    }

    function showBanner() {
      banner.hidden = false;
      // Скрытие плавное через CSS-переход — ставим класс через rAF чтобы opacity-переход сработал.
      requestAnimationFrame(function () { banner.classList.add('is-visible'); });
    }

    function hideBanner() {
      banner.classList.remove('is-visible');
      // После окончания transition — окончательно скрыть (250ms = --duration-normal).
      setTimeout(function () { banner.hidden = true; }, 280);
    }

    function readCheckedCategories() {
      var inputs = banner.querySelectorAll('input[type="checkbox"][data-cat]');
      var result = { necessary: true, analytics: false, marketing: false };
      for (var i = 0; i < inputs.length; i++) {
        var inp = inputs[i];
        var cat = inp.getAttribute('data-cat');
        if (cat && cat !== 'necessary') {
          result[cat] = inp.checked;
        }
      }
      return result;
    }

    function setCategoryToggles(state) {
      var inputs = banner.querySelectorAll('input[type="checkbox"][data-cat]');
      for (var i = 0; i < inputs.length; i++) {
        var inp = inputs[i];
        var cat = inp.getAttribute('data-cat');
        if (cat === 'necessary') { inp.checked = true; continue; }
        if (cat && Object.prototype.hasOwnProperty.call(state, cat)) {
          inp.checked = !!state[cat];
        }
      }
    }

    function toggleSettings() {
      var settings = banner.querySelector('[data-cookie-settings]');
      var btn = banner.querySelector('[data-cookie-action="toggle-settings"]');
      if (!settings) return;
      var isOpen = !settings.hasAttribute('hidden');
      if (isOpen) {
        settings.setAttribute('hidden', '');
        if (btn) btn.setAttribute('aria-expanded', 'false');
        banner.classList.remove('is-expanded');
      } else {
        settings.removeAttribute('hidden');
        if (btn) btn.setAttribute('aria-expanded', 'true');
        banner.classList.add('is-expanded');
      }
    }

    // Click-handler — делегирование от banner.
    banner.addEventListener('click', function (e) {
      var target = e.target;
      // Найти ближайшую кнопку с data-cookie-action
      while (target && target !== banner && (!target.getAttribute || !target.getAttribute('data-cookie-action'))) {
        target = target.parentElement;
      }
      if (!target || target === banner) return;
      var action = target.getAttribute('data-cookie-action');
      if (action === 'accept-all') {
        writeChoice({ analytics: true, marketing: true });
      } else if (action === 'reject') {
        writeChoice({ analytics: false, marketing: false });
      } else if (action === 'save') {
        writeChoice(readCheckedCategories());
      } else if (action === 'toggle-settings') {
        toggleSettings();
      }
    });

    // Бутстрап
    var existing = readChoice();
    if (!existing) {
      // Новый посетитель — показать баннер
      showBanner();
    } else {
      // Уже выбрано — повторно бросить событие (внешние скрипты могли не подписаться вовремя)
      try {
        window.dispatchEvent(new CustomEvent('termy:cookies-updated', { detail: existing }));
      } catch (e) { /* nop */ }
      // Синхронизировать чекбоксы (для случая, если пользователь откроет настройки повторно)
      setCategoryToggles(existing);
    }

    // Публичный API — для ссылки «Настройки cookies» в footer.
    window.TermyCookies = {
      open: function () {
        var current = readChoice() || { analytics: false, marketing: false };
        setCategoryToggles(current);
        var settings = banner.querySelector('[data-cookie-settings]');
        var btn = banner.querySelector('[data-cookie-action="toggle-settings"]');
        if (settings) settings.removeAttribute('hidden');
        if (btn) btn.setAttribute('aria-expanded', 'true');
        banner.classList.add('is-expanded');
        showBanner();
      },
      get: readChoice,
    };
  })();
</script>

<style>
  /* ── Slim-toast: sticky bottom strip ~52px desktop / ~64px mobile ── */
  .cookie-banner {
    position: fixed;
    inset-inline: 0;
    inset-block-end: 0;
    /* z-index ниже sticky header (--z-sticky обычно 100), выше обычного контента */
    z-index: calc(var(--z-sticky, 100) - 10);
    background: var(--color-bg-page);
    border-block-start: 1px solid var(--color-border-default);
    box-shadow: 0 -4px 16px rgba(20, 24, 28, 0.08);
    padding-block: var(--spacing-2);
    padding-inline: var(--spacing-4);
    padding-block-end: calc(var(--spacing-2) + env(safe-area-inset-bottom, 0px));
    opacity: 0;
    transform: translateY(6px);
    transition: opacity var(--duration-normal) var(--easing-standard),
                transform var(--duration-normal) var(--easing-standard);
    will-change: opacity, transform;
  }
  .cookie-banner.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .cookie-banner[hidden] { display: none; }

  .cookie-banner__inner {
    margin-inline: auto;
    max-width: 1100px;
    display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    gap: var(--spacing-2);
    min-height: 40px;
  }

  .cookie-banner__text {
    flex: 1 1 220px;
    margin: 0;
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    line-height: var(--font-line-height-normal);
  }
  .cookie-banner__text a {
    color: var(--color-action-primary);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  .cookie-banner__text a:hover { text-decoration-thickness: 2px; }

  .cookie-banner__actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    flex-shrink: 0;
  }

  .cookie-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: var(--spacing-1) var(--spacing-4);
    border-radius: var(--radius-base);
    font-family: inherit;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    line-height: 1;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background var(--duration-fast) var(--easing-standard),
                color var(--duration-fast) var(--easing-standard);
  }
  .cookie-banner__btn--primary {
    background: var(--color-action-primary);
    color: var(--color-text-on-brand);
  }
  .cookie-banner__btn--primary:hover { background: var(--color-action-primary-hover); }
  .cookie-banner__btn--ghost {
    background: transparent;
    color: var(--color-text-secondary);
    border-color: transparent;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    padding-inline: var(--spacing-2);
  }
  .cookie-banner__btn--ghost:hover { color: var(--color-text-primary); }
  .cookie-banner__btn:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  /* V4-4 (iter4): main row — обычный slim-toast компактный layout. */
  .cookie-banner__main {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-3);
    width: 100%;
    min-height: 40px;
  }
  .cookie-banner__main .cookie-banner__text { flex: 1 1 220px; margin: 0; }

  /* V4-4: expanded settings panel — раскрывается по «Настроить». */
  .cookie-banner.is-expanded {
    padding-block: var(--spacing-4);
  }
  .cookie-banner__settings {
    width: 100%;
    margin-block-start: var(--spacing-3);
    padding-block-start: var(--spacing-3);
    border-block-start: 1px solid var(--color-border-default);
  }
  .cookie-banner__settings[hidden] { display: none; }

  .cookie-banner__settings-title {
    margin: 0 0 var(--spacing-3);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
  }

  .cookie-cats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-2);
  }
  @media (min-width: 768px) {
    .cookie-cats { grid-template-columns: repeat(3, 1fr); }
  }

  .cookie-cat__label {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: var(--spacing-2);
    row-gap: 2px;
    align-items: start;
    padding: var(--spacing-2) var(--spacing-3);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle, var(--color-border-default));
    border-radius: var(--radius-base);
    cursor: pointer;
    transition: border-color var(--duration-fast) var(--easing-standard);
  }
  .cookie-cat__label:hover { border-color: var(--color-action-primary); }
  .cookie-cat__label input[type="checkbox"] {
    grid-column: 1 / 2;
    grid-row: 1 / 3;
    margin-top: 3px;
    accent-color: var(--color-action-primary);
    cursor: pointer;
  }
  .cookie-cat__label input[type="checkbox"]:disabled { cursor: not-allowed; opacity: 0.7; }
  .cookie-cat__name {
    grid-column: 2 / 3;
    grid-row: 1 / 2;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
  }
  .cookie-cat__desc {
    grid-column: 2 / 3;
    grid-row: 2 / 3;
    font-size: 11px;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .cookie-banner__settings-actions {
    margin-block-start: var(--spacing-3);
    display: flex;
    justify-content: flex-end;
  }

  @media (max-width: 767px) {
    .cookie-banner__inner { min-height: 52px; }
    .cookie-banner__text { font-size: var(--font-size-xs); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cookie-banner,
    .cookie-banner__btn,
    .cookie-cat__label { transition: none; }
    .cookie-banner { transform: none; }
  }
</style>
