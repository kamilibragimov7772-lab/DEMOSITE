---
/**
 * CookieBanner — organism.
 *
 * 152-ФЗ + GDPR-совместимый cookie consent banner.
 * Показывается при первом визите (если в localStorage нет `termy.cookies.v1`).
 * Три категории: necessary (always-on), analytics (Yandex Metrica), marketing (Yandex Direct + Bitrix24 chat).
 *
 * Persistence:
 * - localStorage: `termy.cookies.v1` = JSON {necessary,analytics,marketing,ts,v}
 * - cookie:        `termy_cookie_choice=...; max-age=31536000; path=/; samesite=lax` (1 год)
 *
 * События:
 * - `window.dispatchEvent(new CustomEvent('termy:cookies-updated', { detail }))` — для подключения Yandex Metrica/Direct по согласию.
 *
 * Источники:
 * - 04_visuals/22-legal-cookies.spec.md
 * - 02_content/page_outlines/22-legal-cookies.md (3 категории)
 * - 152-ФЗ ст. 9 (явное согласие)
 * - phase 7 iter2 — closes Security HIGH #1 (cookie consent runtime отсутствует)
 *
 * CSP: inline <script> без external dependencies. nonce-friendly: можно добавить позднее.
 */

import { Icon } from 'astro-icon/components';
---

<aside
  id="cookie-banner"
  class="cookie-banner"
  role="region"
  aria-label="Согласие на использование cookies"
  aria-live="polite"
  hidden
>
  <div class="cookie-banner__inner">
    <div class="cookie-banner__intro">
      <h2 class="cookie-banner__title">Cookies на этом сайте</h2>
      <p class="cookie-banner__text">
        Сайт использует cookies для работы форм, аналитики и улучшения сервиса. Технические cookies нужны всегда, аналитические и маркетинговые — по вашему выбору.
        Подробнее в <a href="/legal/cookies/">политике cookies</a> и <a href="/legal/privacy/">политике конфиденциальности</a> (152-ФЗ).
      </p>
    </div>

    <details class="cookie-banner__settings" data-cookie-settings>
      <summary class="cookie-banner__settings-summary">
        <span>Настроить категории</span>
        <Icon name="lucide:chevron-down" class="cookie-banner__chevron" aria-hidden="true" />
      </summary>

      <fieldset class="cookie-banner__categories">
        <legend class="cookie-banner__legend">Категории cookies</legend>

        <label class="cookie-banner__category cookie-banner__category--locked">
          <input type="checkbox" checked disabled aria-describedby="cb-cat-necessary-desc" data-cat="necessary" />
          <span class="cookie-banner__category-body">
            <span class="cookie-banner__category-title">Необходимые</span>
            <span id="cb-cat-necessary-desc" class="cookie-banner__category-desc">
              Сессия, защита форм от CSRF, сохранение выбора cookies. Отключить нельзя — без них сайт не работает.
            </span>
          </span>
        </label>

        <label class="cookie-banner__category">
          <input type="checkbox" aria-describedby="cb-cat-analytics-desc" data-cat="analytics" />
          <span class="cookie-banner__category-body">
            <span class="cookie-banner__category-title">Аналитика</span>
            <span id="cb-cat-analytics-desc" class="cookie-banner__category-desc">
              Яндекс.Метрика — анонимная статистика посещений и поведения на сайте. Помогает улучшать сервис.
            </span>
          </span>
        </label>

        <label class="cookie-banner__category">
          <input type="checkbox" aria-describedby="cb-cat-marketing-desc" data-cat="marketing" />
          <span class="cookie-banner__category-body">
            <span class="cookie-banner__category-title">Маркетинг</span>
            <span id="cb-cat-marketing-desc" class="cookie-banner__category-desc">
              Яндекс.Директ (ретаргетинг рекламы) и Bitrix24 (онлайн-чат). Помогают показывать релевантные предложения.
            </span>
          </span>
        </label>
      </fieldset>

      <div class="cookie-banner__settings-actions">
        <button type="button" class="cookie-banner__btn cookie-banner__btn--secondary" data-cookie-action="save">
          Сохранить выбор
        </button>
      </div>
    </details>

    <div class="cookie-banner__actions">
      <button type="button" class="cookie-banner__btn cookie-banner__btn--ghost" data-cookie-action="reject">
        Только необходимые
      </button>
      <button type="button" class="cookie-banner__btn cookie-banner__btn--primary" data-cookie-action="accept-all">
        Принять все
      </button>
    </div>
  </div>
</aside>

<script is:inline>
  (function () {
    'use strict';

    var STORAGE_KEY = 'termy.cookies.v1';
    var COOKIE_KEY = 'termy_cookie_choice';
    var COOKIE_MAX_AGE = 60 * 60 * 24 * 365; // 1 год
    var SCHEMA_VERSION = 1;

    var banner = document.getElementById('cookie-banner');
    if (!banner) return;

    function readChoice() {
      try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (!parsed || parsed.v !== SCHEMA_VERSION) return null;
        return parsed;
      } catch (e) {
        return null;
      }
    }

    function writeChoice(choice) {
      var record = {
        v: SCHEMA_VERSION,
        ts: Date.now(),
        necessary: true,
        analytics: !!choice.analytics,
        marketing: !!choice.marketing,
      };
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(record));
      } catch (e) { /* localStorage заблокирован — fallback на cookie */ }
      // Дублируем в cookie на 1 год — чтобы на серверной стороне (Vercel/CF Edge) можно было прочитать.
      var cookieValue = encodeURIComponent(JSON.stringify(record));
      document.cookie = COOKIE_KEY + '=' + cookieValue + '; max-age=' + COOKIE_MAX_AGE + '; path=/; samesite=lax';

      // Сигнал внешним скриптам (Yandex Metrica/Direct/Bitrix24) — подключаться по согласию.
      try {
        window.dispatchEvent(new CustomEvent('termy:cookies-updated', { detail: record }));
      } catch (e) { /* CustomEvent unsupported — игнор */ }

      hideBanner();
    }

    function showBanner() {
      banner.hidden = false;
      // Скрытие плавное через CSS-переход — ставим класс через rAF чтобы opacity-переход сработал.
      requestAnimationFrame(function () { banner.classList.add('is-visible'); });
    }

    function hideBanner() {
      banner.classList.remove('is-visible');
      // После окончания transition — окончательно скрыть (250ms = --duration-normal).
      setTimeout(function () { banner.hidden = true; }, 280);
    }

    function readCheckedCategories() {
      var inputs = banner.querySelectorAll('input[type="checkbox"][data-cat]');
      var result = { necessary: true, analytics: false, marketing: false };
      for (var i = 0; i < inputs.length; i++) {
        var inp = inputs[i];
        var cat = inp.getAttribute('data-cat');
        if (cat && cat !== 'necessary') {
          result[cat] = inp.checked;
        }
      }
      return result;
    }

    function setCategoryToggles(state) {
      var inputs = banner.querySelectorAll('input[type="checkbox"][data-cat]');
      for (var i = 0; i < inputs.length; i++) {
        var inp = inputs[i];
        var cat = inp.getAttribute('data-cat');
        if (cat === 'necessary') { inp.checked = true; continue; }
        if (cat && Object.prototype.hasOwnProperty.call(state, cat)) {
          inp.checked = !!state[cat];
        }
      }
    }

    // Click-handler — делегирование от banner.
    banner.addEventListener('click', function (e) {
      var target = e.target;
      // Найти ближайшую кнопку с data-cookie-action
      while (target && target !== banner && (!target.getAttribute || !target.getAttribute('data-cookie-action'))) {
        target = target.parentElement;
      }
      if (!target || target === banner) return;
      var action = target.getAttribute('data-cookie-action');
      if (action === 'accept-all') {
        writeChoice({ analytics: true, marketing: true });
      } else if (action === 'reject') {
        writeChoice({ analytics: false, marketing: false });
      } else if (action === 'save') {
        writeChoice(readCheckedCategories());
      }
    });

    // Бутстрап
    var existing = readChoice();
    if (!existing) {
      // Новый посетитель — показать баннер
      showBanner();
    } else {
      // Уже выбрано — повторно бросить событие (внешние скрипты могли не подписаться вовремя)
      try {
        window.dispatchEvent(new CustomEvent('termy:cookies-updated', { detail: existing }));
      } catch (e) { /* nop */ }
      // Синхронизировать чекбоксы (для случая, если пользователь откроет настройки повторно)
      setCategoryToggles(existing);
    }

    // Публичный API — для ссылки «Настройки cookies» в footer.
    window.TermyCookies = {
      open: function () {
        var current = readChoice() || { analytics: false, marketing: false };
        setCategoryToggles(current);
        var details = banner.querySelector('[data-cookie-settings]');
        if (details) details.open = true;
        showBanner();
      },
      get: readChoice,
    };
  })();
</script>

<style>
  .cookie-banner {
    position: fixed;
    inset-inline: 0;
    inset-block-end: 0;
    z-index: var(--z-modal);
    background: var(--color-bg-page);
    border-block-start: 1px solid var(--color-border-default);
    box-shadow: 0 -8px 32px rgba(20, 24, 28, 0.12);
    padding: var(--spacing-4) var(--spacing-4) calc(var(--spacing-4) + env(safe-area-inset-bottom, 0px));
    opacity: 0;
    transform: translateY(8px);
    transition: opacity var(--duration-normal) var(--easing-standard), transform var(--duration-normal) var(--easing-standard);
    will-change: opacity, transform;
  }
  .cookie-banner.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .cookie-banner[hidden] { display: none; }

  .cookie-banner__inner {
    margin-inline: auto;
    max-width: 1100px;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .cookie-banner__intro {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .cookie-banner__title {
    margin: 0;
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    line-height: var(--font-line-height-snug);
  }

  .cookie-banner__text {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: var(--font-line-height-normal);
  }
  .cookie-banner__text a {
    color: var(--color-action-primary);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  .cookie-banner__text a:hover,
  .cookie-banner__text a:focus-visible {
    text-decoration-thickness: 2px;
  }

  /* Settings — accordion */
  .cookie-banner__settings {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-base);
    background: var(--color-bg-surface-warm);
  }
  .cookie-banner__settings-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-3);
    padding: var(--spacing-3) var(--spacing-4);
    min-height: 44px;
    cursor: pointer;
    list-style: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }
  .cookie-banner__settings-summary::-webkit-details-marker { display: none; }
  .cookie-banner__settings[open] .cookie-banner__chevron { transform: rotate(180deg); }
  .cookie-banner__chevron {
    width: 16px;
    height: 16px;
    color: var(--color-text-tertiary);
    transition: transform var(--duration-fast) var(--easing-standard);
  }

  .cookie-banner__categories {
    margin: 0;
    padding: 0 var(--spacing-4) var(--spacing-3);
    border: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }
  .cookie-banner__legend { position: absolute; left: -9999px; }

  .cookie-banner__category {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-3);
    align-items: start;
    padding: var(--spacing-3);
    background: var(--color-bg-page);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color var(--duration-fast) var(--easing-standard);
  }
  .cookie-banner__category:hover { border-color: var(--color-border-default); }
  .cookie-banner__category:focus-within { border-color: var(--color-border-focus); box-shadow: var(--shadow-focus-ring); }
  .cookie-banner__category--locked { cursor: not-allowed; opacity: 0.85; }

  .cookie-banner__category input[type='checkbox'] {
    width: 20px;
    height: 20px;
    margin: 2px 0 0;
    accent-color: var(--color-action-primary);
    cursor: pointer;
  }
  .cookie-banner__category--locked input[type='checkbox'] { cursor: not-allowed; }

  .cookie-banner__category-body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }
  .cookie-banner__category-title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }
  .cookie-banner__category-desc {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    line-height: var(--font-line-height-normal);
  }

  .cookie-banner__settings-actions {
    padding: 0 var(--spacing-4) var(--spacing-3);
    display: flex;
    justify-content: flex-end;
  }

  /* Action buttons */
  .cookie-banner__actions {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }
  .cookie-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-2);
    min-height: 44px;
    padding: var(--spacing-3) var(--spacing-5);
    border-radius: var(--radius-base);
    font-family: inherit;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    line-height: 1;
    cursor: pointer;
    border: 1px solid transparent;
    text-align: center;
    transition: background var(--duration-fast) var(--easing-standard),
                border-color var(--duration-fast) var(--easing-standard),
                color var(--duration-fast) var(--easing-standard);
  }
  .cookie-banner__btn--primary {
    background: var(--color-action-primary);
    color: var(--color-text-on-brand);
  }
  .cookie-banner__btn--primary:hover { background: var(--color-action-primary-hover); }
  .cookie-banner__btn--secondary {
    background: var(--color-bg-page);
    color: var(--color-text-primary);
    border-color: var(--color-border-default);
  }
  .cookie-banner__btn--secondary:hover { border-color: var(--color-border-strong); }
  .cookie-banner__btn--ghost {
    background: transparent;
    color: var(--color-text-primary);
    border-color: var(--color-border-default);
  }
  .cookie-banner__btn--ghost:hover { background: var(--color-bg-surface); }
  .cookie-banner__btn:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  /* Tablet+ — растяжка по горизонтали */
  @media (min-width: 768px) {
    .cookie-banner { padding: var(--spacing-5) var(--spacing-6) calc(var(--spacing-5) + env(safe-area-inset-bottom, 0px)); }
    .cookie-banner__inner {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--spacing-5);
    }
    .cookie-banner__intro {
      flex: 1 1 320px;
      min-width: 280px;
    }
    .cookie-banner__settings {
      flex: 1 1 100%;
      order: 3;
    }
    .cookie-banner__actions {
      flex-direction: row;
      flex: 0 0 auto;
      gap: var(--spacing-3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cookie-banner,
    .cookie-banner__chevron,
    .cookie-banner__category,
    .cookie-banner__btn { transition: none; }
    .cookie-banner { transform: none; }
  }
</style>
