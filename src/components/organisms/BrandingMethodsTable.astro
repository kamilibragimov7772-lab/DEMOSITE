---
/**
 * BrandingMethodsTable — organism.
 * Сравнительная таблица методов брендирования по осям:
 *  - МОЗ (минимальный объём)
 *  - макс. цветов / Pantone
 *  - сроки производства
 *  - ценовой фактор
 *  - применимость
 *
 * Используется на /branding/* (3 sub-pages) для инженерного выбора метода.
 *
 * Адаптив: на mobile — горизонтальный scroll-контейнер; на ≥768px — fit table.
 *
 * Источник:
 * - 04_visuals/25-branding-termopakety.spec.md (отсутствует — strategy: используем outline)
 * - 02_content/page_outlines/25-branding-termopakety.md §«Методы нанесения»
 * - components_atomic.md §Organisms (table-comparison)
 */

export interface MethodRow {
  /** Название метода. */
  name: string;
  /** МОЗ. */
  moq: string;
  /** Цвета / возможности. */
  colors: string;
  /** Сроки. */
  terms: string;
  /** Ценовой фактор. */
  priceFactor: string;
  /** Применимость / лучшие случаи. */
  bestFor: string;
}

export interface Props {
  heading: string;
  eyebrow?: string;
  /** Краткое описание под H2. */
  lead?: string;
  rows: ReadonlyArray<MethodRow>;
  /** ID для anchor-link. */
  id?: string;
}

const { heading, eyebrow, lead, rows, id = 'branding-methods' } = Astro.props;
---

<section class="bmt" id={id} aria-labelledby={`${id}-h`}>
  <div class="container">
    {eyebrow && <p class="bmt__eyebrow">{eyebrow}</p>}
    <h2 id={`${id}-h`} class="bmt__h">{heading}</h2>
    {lead && <p class="bmt__lead">{lead}</p>}

    <div class="bmt__scroll" role="region" aria-label="Сравнение методов брендирования (горизонтальная прокрутка)" tabindex="0">
      <table class="bmt__table">
        <caption class="bmt__caption">
          Сравнение методов нанесения логотипа: МОЗ, цвета, сроки, ценовой фактор, применимость
        </caption>
        <thead>
          <tr>
            <th scope="col" class="bmt__th-method">Метод</th>
            <th scope="col">МОЗ</th>
            <th scope="col">Цвета</th>
            <th scope="col">Сроки</th>
            <th scope="col">Цена</th>
            <th scope="col">Когда выбирать</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <th scope="row" class="bmt__th-method">{row.name}</th>
              <td class="num">{row.moq}</td>
              <td>{row.colors}</td>
              <td>{row.terms}</td>
              <td>{row.priceFactor}</td>
              <td class="bmt__best">{row.bestFor}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .bmt {
    padding-block: var(--spacing-7);
    background: var(--color-bg-surface);
  }
  .bmt__eyebrow {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--font-letter-spacing-widest);
    text-transform: uppercase;
    margin-block-end: var(--spacing-3);
  }
  .bmt__h {
    margin-block-end: var(--spacing-3);
    max-width: 36ch;
  }
  .bmt__lead {
    margin-block-end: var(--spacing-5);
    max-width: 56ch;
    color: var(--color-text-secondary);
    line-height: var(--font-line-height-normal);
  }

  .bmt__scroll {
    overflow-x: auto;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-base);
    background: var(--color-bg-page);
  }
  .bmt__scroll:focus-visible {
    outline: 2px solid var(--color-action-primary);
    outline-offset: 2px;
  }

  .bmt__table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
    min-width: 720px;
  }
  .bmt__caption {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .bmt__table thead th {
    padding: var(--spacing-3) var(--spacing-4);
    background: var(--color-bg-surface);
    text-align: left;
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    border-block-end: 2px solid var(--color-border-default);
    white-space: nowrap;
  }
  .bmt__table tbody th,
  .bmt__table tbody td {
    padding: var(--spacing-3) var(--spacing-4);
    border-block-end: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    vertical-align: top;
    line-height: var(--font-line-height-normal);
  }
  .bmt__table tbody tr:last-child th,
  .bmt__table tbody tr:last-child td {
    border-block-end: none;
  }
  .bmt__th-method {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
    text-align: left;
    white-space: nowrap;
  }
  .bmt__best {
    color: var(--color-text-primary);
    min-width: 220px;
  }
  .bmt__table .num {
    font-variant-numeric: tabular-nums;
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
  }

  .bmt__table tbody tr {
    transition: background-color var(--duration-fast) var(--easing-standard);
  }
  .bmt__table tbody tr:hover {
    background: var(--color-bg-surface-warm);
  }

  @media (prefers-reduced-motion: reduce) {
    .bmt__table tbody tr { transition: none; }
  }
</style>
