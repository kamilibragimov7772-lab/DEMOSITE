---
/**
 * HeroLanding — organism.
 * Composition: Eyebrow + H1 + Lead + CTA-row (Primary + Secondary) + Stats-strip 4 плитки + декоративный фон-overlay.
 * Entrance: stagger fade-up детей с 50-80ms delay; reduced-motion → instant.
 *
 * Источники:
 * - 04_visuals/01-homepage.spec.md §«Block 2: Hero — landing»
 * - 02_content/page_outlines/01-homepage.md §«Hero block»
 * - 04_visuals/_motion_applied.md §«Per-page hero entrances» (homepage)
 * - tone_of_voice.md §«Hero CTA Primary» п.1+6
 */

import Button from '@components/atoms/Button.astro';
import Stat from '@components/molecules/Stat.astro';

export interface HeroStat {
  value: string;
  label: string;
}

export interface Props {
  eyebrow: string;
  /** Полный H1 (≤120 симв; в outline'ах из page_outlines/). */
  h1: string;
  lead: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  stats: ReadonlyArray<HeroStat>;
}

const { eyebrow, h1, lead, primaryCta, secondaryCta, stats } = Astro.props;
---

<section class="hero" aria-labelledby="hero-h1" data-motion="hero" data-hero>
  <div class="hero__decor" aria-hidden="true" data-motion="blob"></div>
  <div class="hero__inner container">
    <div class="hero__text">
      <p class="hero__eyebrow stagger-child" style="--stagger-i: 0">{eyebrow}</p>
      <h1 id="hero-h1" class="hero__h1 stagger-child" style="--stagger-i: 1">{h1}</h1>
      <p class="hero__lead stagger-child" style="--stagger-i: 2">{lead}</p>
      <div class="hero__cta stagger-child" style="--stagger-i: 3">
        <Button variant="primary" size="lg" href={primaryCta.href}>{primaryCta.label}</Button>
        {secondaryCta && (
          <Button variant="inverse" size="lg" href={secondaryCta.href}>{secondaryCta.label}</Button>
        )}
      </div>
      <ul class="hero__stats stagger-child" style="--stagger-i: 4" role="list">
        {stats.map((s) => (
          <li>
            <Stat value={s.value} label={s.label} size="base" variant="surface" />
          </li>
        ))}
      </ul>
    </div>
    <div class="hero__visual" aria-hidden="true">
      <div class="prod-stage">
        <div class="prod-glow"></div>
        <img class="prod-item" data-prod="0" src="/products/_hero/termopaket-42x45.webp" alt="" loading="eager" decoding="async" />
        <img class="prod-item" data-prod="1" src="/products/_hero/shock-600-cool.webp" alt="" loading="eager" decoding="async" />
        <img class="prod-item" data-prod="2" src="/products/_hero/linerbox-24l.webp" alt="" loading="eager" decoding="async" />
        <img class="prod-item" data-prod="3" src="/products/_hero/termoshopper.webp" alt="" loading="eager" decoding="async" />
        <img class="prod-item" data-prod="4" src="/products/_hero/zip-lock.webp" alt="" loading="eager" decoding="async" />
        <img class="prod-item" data-prod="5" src="/products/_hero/shock-450-gel.webp" alt="" loading="eager" decoding="async" />
      </div>
    </div>
  </div>
</section>

<script is:inline>
  /**
   * Sync hero product-pile animation со снятием splash.
   * Сценарии:
   *  1. Splash отыгрывает (первый visit) → ждём пока [data-splash] удалится из DOM, тогда .is-ready.
   *  2. Splash skip (sessionStorage seen ИЛИ reduced-motion) → SplashIntro ставит display:none сразу,
   *     значит запускаем hero мгновенно.
   *  3. Splash element вообще нет на странице → запуск мгновенно.
   *  4. Reduced motion → запуск мгновенно (анимация в этом случае выключена через @media).
   *  5. Fallback на 2.5s, если по какой-то причине MutationObserver не сработает.
   */
  (() => {
    const hero = document.querySelector('[data-hero]');
    if (!hero) return;

    const splash = document.querySelector('[data-splash]');
    const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const splashActive = !!splash && splash.style.display !== 'none';

    if (reduceMotion || !splashActive) {
      hero.classList.add('is-ready');
      return;
    }

    /* Splash активен — ждём его удаления из DOM. */
    const observer = new MutationObserver(() => {
      if (!document.querySelector('[data-splash]')) {
        hero.classList.add('is-ready');
        observer.disconnect();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });

    /* Fallback на 2.5s — на случай если SplashIntro JS сломан. */
    setTimeout(() => {
      hero.classList.add('is-ready');
      observer.disconnect();
    }, 2500);
  })();
</script>

<style>
  .hero {
    position: relative;
    overflow: clip;
    padding-block: var(--spacing-7) var(--spacing-8);
    background: var(--color-bg-page);
    isolation: isolate;
  }

  /* Фон hero: фото склада/цеха + тёмный gradient-overlay для читаемости.
     Слева overlay плотнее (там текст), справа легче (там продукты pile). */
  .hero__decor {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        95deg,
        rgba(10, 6, 24, 0.86) 0%,
        rgba(15, 10, 30, 0.7) 45%,
        rgba(30, 18, 60, 0.5) 75%,
        rgba(40, 22, 80, 0.4) 100%
      ),
      url('/assets/hero/warehouse-bg.jpg') center / cover no-repeat;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-5);
    max-width: var(--container-max);
    align-items: center;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
    min-width: 0;
  }

  /* Mobile / tablet: визуал скрыт по решению — показываем только текстовый блок. */
  .hero__visual { display: none; }

  .hero__eyebrow {
    /* На тёмном overlay фиолетовый сложно читается — делаем светлее brand-tint. */
    color: #C8A8E8;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--font-letter-spacing-widest);
    text-transform: uppercase;
  }

  .hero__h1 {
    max-width: 22ch;
    font-size: var(--font-size-h1-fluid);
    font-weight: var(--font-weight-bold);
    line-height: var(--font-line-height-tight);
    letter-spacing: var(--font-letter-spacing-tighter);
    color: #ffffff;
    /* Лёгкая drop-shadow для читаемости поверх фото */
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.35);
  }

  .hero__lead {
    max-width: 56ch;
    color: rgba(255, 255, 255, 0.88);
    font-size: var(--font-size-md);
    line-height: var(--font-line-height-normal);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.25);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-3);
    margin: 0;
    padding: 0;
    list-style: none;
    margin-block-start: var(--spacing-4);
  }

  /* Hero entrance — stagger fade-up детей (5 элементов × 60ms delay).
     Источник: motion_applied.md §«Per-page hero entrances» homepage. */
  .stagger-child {
    opacity: 0;
    transform: translateY(16px);
    animation: hero-stagger-up var(--duration-hero) var(--easing-decelerate) forwards;
    animation-delay: calc(var(--stagger-i, 0) * 60ms);
  }
  /* H1 — LCP-кандидат на mobile (визуал hero скрыт <1024px).
     Не fade'им opacity, чтобы LCP не задерживался на ~600ms. Только slide-up. */
  .hero__h1.stagger-child {
    opacity: 1;
    animation-name: hero-slide-up;
  }
  @keyframes hero-stagger-up {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-slide-up {
    from { transform: translateY(16px); }
    to { transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .stagger-child { animation: none; opacity: 1; transform: none; }
    .hero__decor { transform: none !important; }
  }

  @media (min-width: 768px) {
    .hero { padding-block: var(--spacing-8) var(--spacing-9); }
    .hero__cta { flex-direction: row; }
    .hero__stats { grid-template-columns: repeat(4, 1fr); }
  }
  @media (min-width: 1024px) {
    .hero__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--spacing-7);
    }
    .hero__visual {
      display: block;
      position: relative;
      width: 100%;
      aspect-ratio: 5 / 4;
      max-height: 520px;
    }
  }
  @media (min-width: 1280px) {
    .hero__inner {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      gap: var(--spacing-8);
    }
  }

  /* ── Product pile composition ─────────────────────────────────────────────
     6 продуктов прилетают с РАЗНЫХ направлений (не все снизу), собираются
     в композицию, на приземлении дают burst фиолетового glow, потом мягко float'ят.
     Старт анимации синхронизирован со снятием splash через JS (см. inline script ниже).
     Каждый продукт настраивает: --start-x, --start-y, --start-rot, --target-rot. */
  .prod-stage {
    position: absolute;
    inset: 0;
  }

  /* «Стольная» тень — общий тёмный ellipse под всей композицией,
     читается как поверхность стола, на которой стоят все продукты.
     Появляется после полного приземления (delay 1.7s), плавно проявляется. */
  .prod-stage::after {
    content: '';
    position: absolute;
    bottom: 4%;
    left: 8%;
    right: 8%;
    height: 10%;
    background: radial-gradient(
      ellipse at center,
      rgba(20, 14, 38, 0.28) 0%,
      rgba(20, 14, 38, 0.12) 35%,
      transparent 70%
    );
    filter: blur(12px);
    z-index: 0;
    opacity: 0;
    pointer-events: none;
    transform: scaleX(0.6);
    transform-origin: center;
    animation: prod-table-shadow-in 0.8s cubic-bezier(.16, 1, .3, 1) 1.7s forwards;
    animation-play-state: paused;
  }
  .hero.is-ready .prod-stage::after {
    animation-play-state: running;
  }
  @keyframes prod-table-shadow-in {
    from { opacity: 0; transform: scaleX(0.6); }
    to   { opacity: 1; transform: scaleX(1);   }
  }

  .prod-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 88%;
    height: 74%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      ellipse,
      var(--color-overlay-brand-tint-low) 0%,
      transparent 65%
    );
    filter: blur(28px);
    z-index: 0;
    pointer-events: none;
    animation: prod-glow-pulse 6s ease-in-out infinite;
    opacity: 0.6;
  }

  @keyframes prod-glow-pulse {
    0%, 100% { opacity: 0.45; }
    50% { opacity: 0.75; }
  }

  .prod-item {
    position: absolute;
    object-fit: contain;
    opacity: 0;
    filter: contrast(1.05) drop-shadow(0 14px 22px rgba(20, 14, 38, 0.18));
    will-change: transform, opacity, filter;
    animation-fill-mode: both;
    animation-play-state: paused; /* Снимается JS-ом после splash или сразу если splash skip */
    transition: transform var(--duration-slow) var(--easing-decelerate),
                filter var(--duration-slow) var(--easing-decelerate);
  }

  /* Запуск анимации: hero получает .is-ready через JS, когда splash ушёл (или сразу). */
  .hero.is-ready .prod-item {
    animation-play-state: running;
  }

  .prod-item:hover {
    transform: translateY(-6px) rotate(var(--target-rot)) scale(1.04);
    filter: contrast(1.1) drop-shadow(0 22px 32px rgba(20, 14, 38, 0.28));
    z-index: 10;
  }

  /* Tabletop-композиция: продукты сгруппированы как на одной поверхности,
     минимальные ротации (предметы лежат/стоят, а не «парят»), плотный overlap по глубине,
     общий источник света сверху (drop-shadows вниз-вправо).
     Размеры ~+12% к предыдущей раскладке для bolder presence. */

  /* Термопакет — центральный biggest, СТОЯЩИЙ. Фон композиции. Прилетает СВЕРХУ-СЛЕВА. */
  .prod-item[data-prod="0"] {
    top: 4%;
    left: 26%;
    width: 50%;
    --start-x: -180px;
    --start-y: -140px;
    --start-rot: -45deg;
    --target-rot: -2deg;
    z-index: 2;
    animation:
      prod-fly-in 1s cubic-bezier(.34, 1.4, .35, 1) 0s both,
      prod-float 5.5s ease-in-out 1.5s infinite;
  }
  /* SHOCK 600 — облокотился слева о центральный термопакет. Прилетает СЛЕВА. */
  .prod-item[data-prod="1"] {
    top: 36%;
    left: 2%;
    width: 34%;
    --start-x: -260px;
    --start-y: 40px;
    --start-rot: -55deg;
    --target-rot: -5deg;
    z-index: 3;
    animation:
      prod-fly-in 1s cubic-bezier(.34, 1.4, .35, 1) 0.15s both,
      prod-float 6s ease-in-out 1.7s infinite;
  }
  /* LinerBox 24L — крупный, справа от термопакета, частично перекрывает. */
  .prod-item[data-prod="2"] {
    top: 26%;
    left: 58%;
    width: 42%;
    --start-x: 280px;
    --start-y: 60px;
    --start-rot: 50deg;
    --target-rot: 4deg;
    z-index: 3;
    animation:
      prod-fly-in 1s cubic-bezier(.34, 1.4, .35, 1) 0.3s both,
      prod-float 5.8s ease-in-out 1.9s infinite;
  }
  /* Термошоппер — лежит впереди-слева на «столе». */
  .prod-item[data-prod="3"] {
    top: 56%;
    left: 18%;
    width: 34%;
    --start-x: 0px;
    --start-y: 240px;
    --start-rot: -20deg;
    --target-rot: 2deg;
    z-index: 5;
    animation:
      prod-fly-in 1s cubic-bezier(.34, 1.4, .35, 1) 0.45s both,
      prod-float 6.5s ease-in-out 2.1s infinite;
  }
  /* Zip-Lock — лежит впереди-справа. */
  .prod-item[data-prod="4"] {
    top: 60%;
    left: 46%;
    width: 34%;
    --start-x: 220px;
    --start-y: 220px;
    --start-rot: 60deg;
    --target-rot: -3deg;
    z-index: 5;
    animation:
      prod-fly-in 1s cubic-bezier(.34, 1.4, .35, 1) 0.6s both,
      prod-float 5.2s ease-in-out 2.3s infinite;
  }
  /* SHOCK 450 Gel — top-right accent, маленький, чуть позади. */
  .prod-item[data-prod="5"] {
    top: 2%;
    left: 72%;
    width: 28%;
    --start-x: 220px;
    --start-y: -200px;
    --start-rot: 70deg;
    --target-rot: 6deg;
    z-index: 1;
    animation:
      prod-fly-in 1s cubic-bezier(.34, 1.4, .35, 1) 0.75s both,
      prod-float 6.2s ease-in-out 2.5s infinite;
  }

  /* Прилёт + landing burst (фиолетовое свечение в момент приземления, 60% frame). */
  @keyframes prod-fly-in {
    0% {
      opacity: 0;
      transform: translate(var(--start-x), var(--start-y)) scale(0.35) rotate(var(--start-rot));
      filter: contrast(1.05) drop-shadow(0 8px 12px rgba(20, 14, 38, 0.05));
    }
    55% {
      opacity: 1;
    }
    65% {
      opacity: 1;
      transform: translate(0, -10px) scale(1.06) rotate(var(--target-rot));
      filter: contrast(1.18) drop-shadow(0 28px 36px rgba(100, 40, 160, 0.42));
    }
    100% {
      opacity: 1;
      transform: translate(0, 0) scale(1) rotate(var(--target-rot));
      filter: contrast(1.05) drop-shadow(0 14px 22px rgba(20, 14, 38, 0.18));
    }
  }
  /* Float чуть-чуть на столе — едва заметное «дыхание», максимум 2px,
     чтобы не выглядело будто продукты летают, а как будто чуть колеблются на поверхности. */
  @keyframes prod-float {
    0%, 100% { transform: translateY(0) rotate(var(--target-rot)); }
    50%      { transform: translateY(-2px) rotate(calc(var(--target-rot) + 0.3deg)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .prod-item {
      animation: none;
      opacity: 1;
      transform: rotate(var(--target-rot));
      animation-play-state: running;
    }
    .prod-glow { animation: none; }
  }

  /* На mobile — primary/secondary CTAs full-width (per spec — Touch-targets section). */
  @media (max-width: 767px) {
    .hero__cta { flex-direction: column; align-items: stretch; }
    .hero__cta :global(.btn) { width: 100%; }
  }
</style>
