---
/**
 * PDPGallery — organism.
 * Image gallery для PDP (Product Detail Page).
 *
 * Composition:
 *   - <figure>: main image + figcaption (title)
 *   - <nav>: thumbnail-list (kebab list, role=list)
 *   - lightbox-on-click (toggle через details/summary без JS-зависимости)
 *
 * Состояния (по spec 15-pdp-template):
 *   - default — main image + 4-6 thumbs
 *   - loading skeleton — pure CSS shimmer, активируется когда images=[]
 *   - lightbox-open — полноэкранный режим (через CSS :target)
 *   - active thumb — outline brand
 *
 * Motion:
 *   - thumbnail click → main image fade `fast` `decelerate`
 *   - reduced-motion → snap (через global `prefers-reduced-motion`)
 *
 * Touch targets:
 *   - thumbnails: 64×64 desktop, 56×56 mobile (≥44 hit)
 *   - lightbox close: ≥48
 *
 * Источник:
 *   - 04_visuals/15-pdp-template.spec.md §«Block: Hero — PDP»
 *   - 02_content/page_outlines/15-product-card-template.md §«Блок 4. Hero»
 *   - components_atomic.md §Organisms (Image-gallery)
 */

export interface PDPImage {
  /** Полный URL или путь к изображению. */
  src: string;
  /** alt — обязательно для всех product-photos (a11y). */
  alt: string;
  /** Опц. подпись для figcaption (если нужна расширенная). */
  caption?: string;
}

export interface Props {
  /** Список изображений (1-12 шт по spec). Если пустой — рендерится skeleton. */
  images: ReadonlyArray<PDPImage>;
  /** Заголовок продукта — для default figcaption. */
  productTitle: string;
  /** id галереи (для уникальности, если несколько на странице). */
  id?: string;
}

const { images, productTitle, id = 'pdp-gallery' } = Astro.props;

const hasImages = images.length > 0;
const main = hasImages ? images[0]! : null;
---

<section class="pdpg" aria-label={`Галерея фото — ${productTitle}`}>
  {hasImages ? (
    <>
      <figure class="pdpg__figure" id={`${id}-main`}>
        <div class="pdpg__main-wrap">
          <img
            class="pdpg__main"
            src={main!.src}
            alt={main!.alt}
            loading="eager"
            decoding="async"
            width="800"
            height="800"
          />
          {/* Lightbox toggle — pure-CSS через :target */}
          <a
            class="pdpg__zoom"
            href={`#${id}-lightbox`}
            aria-label="Открыть фото в полноэкранном режиме"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
              <line x1="11" y1="8" x2="11" y2="14" />
              <line x1="8" y1="11" x2="14" y2="11" />
            </svg>
          </a>
        </div>
        {main!.caption && (
          <figcaption class="pdpg__caption">{main!.caption}</figcaption>
        )}
      </figure>

      {images.length > 1 && (
        <nav class="pdpg__nav" aria-label="Миниатюры">
          <ul class="pdpg__thumbs" role="list">
            {images.map((img, idx) => (
              <li>
                <a
                  class:list={['pdpg__thumb', idx === 0 && 'pdpg__thumb--active']}
                  href={`#${id}-img-${idx}`}
                  aria-label={`Показать фото ${idx + 1} из ${images.length}: ${img.alt}`}
                  aria-current={idx === 0 ? 'true' : undefined}
                >
                  <img
                    src={img.src}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    width="80"
                    height="80"
                  />
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      {/* Lightbox — pure-CSS via :target. На mobile открывается на полный экран.
          JS прогрессивно расширяет: Esc-key закрытие + focus-trap + focus-restore. */}
      <dialog
        class="pdpg__lightbox"
        id={`${id}-lightbox`}
        aria-label={`Полноэкранное фото — ${productTitle}`}
        data-pdpg-lightbox={id}
      >
        <a
          class="pdpg__lightbox-close"
          href="#"
          aria-label="Закрыть полноэкранный просмотр"
          data-pdpg-close
        >×</a>
        <img
          class="pdpg__lightbox-img"
          src={main!.src}
          alt={main!.alt}
          decoding="async"
        />
      </dialog>
    </>
  ) : (
    <div class="pdpg__skeleton" aria-hidden="true">
      <div class="pdpg__skel-main" />
      <div class="pdpg__skel-thumbs">
        <div /><div /><div /><div />
      </div>
      <p class="pdpg__skel-note">Продакт-съёмка SKU в графике</p>
    </div>
  )}
</section>

<style>
  .pdpg {
    --pdpg-radius: var(--radius-base);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  /* === Main figure === */
  .pdpg__figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }
  .pdpg__main-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--color-bg-surface);
    border-radius: var(--pdpg-radius);
    overflow: hidden;
    border: 1px solid var(--color-border-subtle);
  }
  .pdpg__main {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .pdpg__zoom {
    position: absolute;
    top: var(--spacing-3);
    right: var(--spacing-3);
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-page);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--easing-standard),
      border-color var(--duration-fast) var(--easing-standard),
      transform var(--duration-fast) var(--easing-standard);
  }
  .pdpg__zoom:hover,
  .pdpg__zoom:focus-visible {
    color: var(--color-action-primary);
    border-color: var(--color-action-primary);
    transform: scale(1.04);
  }
  .pdpg__caption {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-xs);
    font-style: italic;
    line-height: var(--font-line-height-normal);
  }

  /* === Thumbnails === */
  .pdpg__nav {
    /* horizontal scroll on mobile */
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }
  .pdpg__thumbs {
    display: flex;
    gap: var(--spacing-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .pdpg__thumb {
    display: block;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 2px solid var(--color-border-subtle);
    background: var(--color-bg-surface);
    transition: border-color var(--duration-fast) var(--easing-standard);
  }
  .pdpg__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pdpg__thumb:hover,
  .pdpg__thumb:focus-visible {
    border-color: var(--color-action-primary);
  }
  .pdpg__thumb--active {
    border-color: var(--color-action-primary);
    box-shadow: 0 0 0 1px var(--color-action-primary) inset;
  }

  /* === Lightbox (pure CSS via dialog open + :target fallback) === */
  .pdpg__lightbox {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    max-width: none;
    max-height: none;
    margin: 0;
    padding: 0;
    border: none;
    background: var(--color-overlay-scrim-blackout);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .pdpg__lightbox:target {
    display: flex;
  }
  .pdpg__lightbox-img {
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
  }
  .pdpg__lightbox-close {
    position: absolute;
    top: var(--spacing-4);
    right: var(--spacing-4);
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-on-dark);
    background: var(--color-overlay-scrim-mid);
    border: 1px solid var(--color-overlay-on-dark-strong);
    border-radius: var(--radius-pill);
    text-decoration: none;
    font-size: 28px;
    line-height: 1;
  }
  .pdpg__lightbox-close:hover,
  .pdpg__lightbox-close:focus-visible {
    background: var(--color-overlay-scrim-high);
    border-color: var(--color-text-on-dark);
  }

  /* === Skeleton === */
  .pdpg__skeleton {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }
  .pdpg__skel-main {
    aspect-ratio: 1 / 1;
    background: linear-gradient(
      90deg,
      var(--color-bg-surface) 0%,
      var(--color-bg-surface-warm) 50%,
      var(--color-bg-surface) 100%
    );
    background-size: 200% 100%;
    animation: pdpg-shimmer 1.6s linear infinite;
    border-radius: var(--pdpg-radius);
  }
  .pdpg__skel-thumbs {
    display: flex;
    gap: var(--spacing-2);
  }
  .pdpg__skel-thumbs > div {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-sm);
    background: var(--color-bg-surface);
  }
  .pdpg__skel-note {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-xs);
    font-style: italic;
    margin: 0;
  }

  @keyframes pdpg-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pdpg__skel-main { animation: none; }
    .pdpg__zoom { transition: none; }
    .pdpg__zoom:hover,
    .pdpg__zoom:focus-visible { transform: none; }
  }

  /* === Tablet/Desktop === */
  @media (min-width: 768px) {
    .pdpg__thumb { width: 72px; height: 72px; }
  }
  @media (min-width: 1024px) {
    .pdpg__thumb { width: 80px; height: 80px; }
  }
</style>

<script>
  /**
   * PDPGallery — progressive enhancement для lightbox a11y.
   * No-JS fallback: open/close через :target + href="#" работает.
   * JS добавляет:
   *   - Esc-key: закрывает lightbox (history.back чтобы убрать hash)
   *   - focus restore: возврат фокуса на zoom-trigger при close
   *   - initial focus: на close-button когда lightbox активирован
   */
  (() => {
    const lightboxes = document.querySelectorAll<HTMLDialogElement>('[data-pdpg-lightbox]');
    if (lightboxes.length === 0) return;

    let lastFocused: HTMLElement | null = null;

    const isLightboxOpen = (lb: HTMLDialogElement): boolean => {
      return location.hash === `#${lb.id}`;
    };

    const closeLightbox = (): void => {
      // Убираем hash через history (без перезагрузки)
      if (location.hash.length > 0) {
        history.replaceState(null, '', location.pathname + location.search);
      }
      // Restore focus
      if (lastFocused) {
        lastFocused.focus();
        lastFocused = null;
      }
    };

    const onHashChange = (): void => {
      lightboxes.forEach((lb) => {
        if (isLightboxOpen(lb)) {
          // Сохраняем кто был активен до открытия
          const trigger = document.querySelector<HTMLElement>(`a[href="#${lb.id}"]`);
          if (trigger && document.activeElement !== trigger) {
            // Если активный — не trigger, всё равно сохраняем trigger как restore-цель
            lastFocused = (document.activeElement as HTMLElement) ?? trigger;
          } else {
            lastFocused = trigger;
          }
          // Перевести фокус на close (next tick, чтобы :target отработал)
          requestAnimationFrame(() => {
            const closeBtn = lb.querySelector<HTMLElement>('[data-pdpg-close]');
            closeBtn?.focus();
          });
        }
      });
    };

    const onKeydown = (e: KeyboardEvent): void => {
      if (e.key !== 'Escape') return;
      const anyOpen = Array.from(lightboxes).some(isLightboxOpen);
      if (anyOpen) {
        e.preventDefault();
        closeLightbox();
      }
    };

    // Click on close-button → также chistим focus state
    lightboxes.forEach((lb) => {
      const closeBtn = lb.querySelector<HTMLAnchorElement>('[data-pdpg-close]');
      closeBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        closeLightbox();
      });
    });

    window.addEventListener('hashchange', onHashChange);
    document.addEventListener('keydown', onKeydown);

    // Initial state (если страница загружена с #...lightbox в URL)
    if (Array.from(lightboxes).some(isLightboxOpen)) {
      onHashChange();
    }
  })();
</script>
