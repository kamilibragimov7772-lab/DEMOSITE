---
/**
 * FormBlock — organism.
 * Универсальная B2B-форма «Получить расчёт» / «Калькулятор-тизер» / «Final CTA».
 * Состояния: idle / submitting / success / error (через client-script + ARIA-live).
 *
 * Variants:
 *   - calculator — 5 полей (продукция / тираж / брендирование / контакт / 152-ФЗ).
 *   - lead       — 4 поля (Имя / Компания / Телефон / Комментарий + 152-ФЗ).
 *   - compact    — 2 поля (Телефон / 152-ФЗ).
 *
 * Каждая форма имеет:
 *   - 152-ФЗ согласие (обязательно по российскому законодательству).
 *   - aria-live="polite" регион для статус-сообщений (success / error).
 *   - novalidate на <form> + кастомная HTML5-валидация на client-script.
 *   - data-form="<variant>" атрибут — для analytics в будущем.
 *
 * Submission: action+method (по умолчанию `/api/leads/<variant>/`); script делает fetch.
 * Если backend ещё не реализован — прогрессивно работает как обычный POST на placeholder.
 *
 * Источник:
 * - 04_visuals/01-homepage.spec.md §«Block 10: Калькулятор-тизер» + §«Block 12: Final CTA Form»
 * - 02_content/page_outlines/01-homepage.md §«H2: Посчитайте партию...» + §«H2: Получить расчёт термоупаковки»
 * - components_atomic.md §Organisms (Form-block)
 * - tone_of_voice.md §Form-submit п.18-22
 */

import FormField from '@components/molecules/FormField.astro';
import Button from '@components/atoms/Button.astro';

type Variant = 'calculator' | 'lead' | 'compact';

export interface Props {
  /** Идентификатор формы — для уникальности input id (когда несколько форм на странице). */
  id: string;
  variant?: Variant;
  /** H2 секции (или h3 при вложенности). */
  heading: string;
  /** Краткое описание над формой. */
  description?: string;
  eyebrow?: string;
  /** Текст submit-кнопки (per tone). Default — «Получить расчёт →». */
  submitLabel?: string;
  /** Action endpoint для отправки. */
  action?: string;
  /** Текст success-message. */
  successText?: string;
  /** Текст error-message. */
  errorText?: string;
  /** Heading-level: section использует h2; внутри карточки — h3. */
  headingLevel?: 'h2' | 'h3';
  /** SLA-подпись под submit-кнопкой (default — «Менеджер свяжется в течение 2 часов в рабочее время»). */
  slaText?: string;
  /** Шаги «Что произойдёт после заявки». */
  nextSteps?: { number: string; title: string }[];
}

const {
  id,
  variant = 'lead',
  heading,
  description,
  eyebrow,
  submitLabel = 'Получить расчёт →',
  action = `/api/leads/${id}/`,
  successText = 'Спасибо! Менеджер свяжется в течение 2 часов.',
  errorText = 'Что-то пошло не так. Параллельный канал — WhatsApp +7 (800) 101-15-25.',
  headingLevel = 'h2',
  slaText = 'Менеджер свяжется в течение 2 часов в рабочее время (Пн–Пт, 09:00–18:00 МСК)',
  nextSteps = [
    { number: '1', title: 'Получим заявку и свяжемся в течение 2 часов' },
    { number: '2', title: 'Согласуем требования и объёмы' },
    { number: '3', title: 'Бесплатно подготовим комплектацию + расчёт' },
    { number: '4', title: 'Отгрузка от 24 ч с момента согласования' },
  ],
} = Astro.props;

const Heading = headingLevel;
const HEADING_ID = `${id}-h`;
const STATUS_ID = `${id}-status`;
---

<section class="formblock" aria-labelledby={HEADING_ID}>
  <div class="container">
    <div class="formblock__head">
      {eyebrow && <p class="formblock__eyebrow">{eyebrow}</p>}
      <Heading id={HEADING_ID} class="formblock__h">{heading}</Heading>
      {description && <p class="formblock__desc">{description}</p>}
    </div>

    {nextSteps && nextSteps.length > 0 && (
      <ol class="formblock__steps" role="list" aria-label="Что произойдёт после заявки">
        {nextSteps.map((s) => (
          <li class="formblock__step">
            <span class="formblock__step-num">{s.number}</span>
            <span class="formblock__step-title">{s.title}</span>
          </li>
        ))}
      </ol>
    )}

    <form
      class="formblock__form"
      id={`form-${id}`}
      action={action}
      method="post"
      novalidate
      data-form={variant}
      data-form-id={id}
      aria-describedby={STATUS_ID}
    >
      {variant === 'calculator' && (
        <>
          <FormField
            id={`${id}-product`}
            name="product"
            type="select"
            label="Какая продукция нужна"
            required
            options={[
              { value: '',                       label: '— Выберите категорию —' },
              { value: 'termopakety',            label: 'Термопакеты' },
              { value: 'akkumulyatory-holoda',   label: 'Аккумуляторы холода SHOCK®' },
              { value: 'zhidkie-hladoelementy', label: 'Жидкие хладоэлементы' },
              { value: 'bablpak',                label: 'БаблПак' },
              { value: 'termosumki-bolshie',    label: 'Термосумки большие' },
              { value: 'termoshoppery',          label: 'Термошопперы' },
              { value: 'mix',                    label: 'Комплект (несколько категорий)' },
            ]}
          />
          <FormField
            id={`${id}-volume`}
            name="volume"
            type="text"
            label="Тираж / объём партии"
            placeholder="Например, 10 000 шт"
            required
            inputmode="numeric"
            helper="Можно ориентировочно — уточним на этапе расчёта"
          />
          <FormField
            id={`${id}-branding`}
            name="branding"
            type="select"
            label="Брендирование"
            options={[
              { value: 'no',           label: 'Без брендирования' },
              { value: 'logo',         label: 'Лого 1-2 цвета' },
              { value: 'full-color',   label: 'Полноцвет / Pantone' },
              { value: 'custom',       label: 'Свой вариант (опишу в комментарии)' },
            ]}
          />
          <FormField
            id={`${id}-phone`}
            name="phone"
            type="tel"
            label="Телефон"
            placeholder="+7 (___) ___-__-__"
            required
            autocomplete="tel"
            inputmode="tel"
            pattern="\+?[0-9\s\(\)\-]{10,}"
            helper="Или email — укажите в комментарии"
          />
        </>
      )}

      {variant === 'lead' && (
        <>
          <div class="formblock__row">
            <FormField
              id={`${id}-name`}
              name="name"
              type="text"
              label="Имя"
              placeholder="Иван"
              autocomplete="given-name"
            />
            <FormField
              id={`${id}-company`}
              name="company"
              type="text"
              label="Компания"
              placeholder="ООО «...»"
              autocomplete="organization"
            />
          </div>
          <FormField
            id={`${id}-phone`}
            name="phone"
            type="tel"
            label="Телефон"
            placeholder="+7 (___) ___-__-__"
            required
            autocomplete="tel"
            inputmode="tel"
            pattern="\+?[0-9\s\(\)\-]{10,}"
          />
          <FormField
            id={`${id}-comment`}
            name="comment"
            type="textarea"
            label="Комментарий"
            placeholder="Опишите задачу: какую продукцию, тираж, брендирование, сроки. Чем подробнее — тем быстрее расчёт."
            rows={4}
          />
        </>
      )}

      {variant === 'compact' && (
        <FormField
          id={`${id}-phone`}
          name="phone"
          type="tel"
          label="Телефон"
          placeholder="+7 (___) ___-__-__"
          required
          autocomplete="tel"
          inputmode="tel"
        />
      )}

      <label class="formblock__consent">
        <input
          id={`${id}-consent`}
          name="consent"
          type="checkbox"
          required
          class="formblock__consent-input"
        />
        <span class="formblock__consent-text">
          Соглашаюсь с обработкой персональных данных согласно
          {' '}<a href="/legal/privacy/">политике конфиденциальности</a>{' '}
          (152-ФЗ)
        </span>
      </label>

      <Button type="submit" variant="primary" size="lg" fullWidth>{submitLabel}</Button>

      {slaText && <p class="formblock__sla">{slaText}</p>}

      <p
        id={STATUS_ID}
        class="formblock__status"
        role="status"
        aria-live="polite"
        data-success-text={successText}
        data-error-text={errorText}
      ></p>
    </form>
  </div>
</section>

<script>
  /**
   * Прогрессивный enhancement для form-block.
   * - Если JS включён: client-side валидация + fetch + status-message.
   * - Если JS выключен: form работает как обычный POST на action endpoint
   *   (ответ сервера должен быть HTML-страницей или 302 на success-страницу).
   */
  type FormStatusElement = HTMLElement & { dataset: DOMStringMap };

  function init(form: HTMLFormElement): void {
    const status = document.getElementById(`${form.dataset.formId ?? ''}-status`) as FormStatusElement | null;
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');

    form.addEventListener('submit', async (e) => {
      // Кастомная валидация — поднимем :invalid стили без showAlert.
      if (!form.checkValidity()) {
        e.preventDefault();
        form.classList.add('is-validated');
        const firstInvalid = form.querySelector<HTMLInputElement>(':invalid');
        firstInvalid?.focus();
        if (status) {
          status.classList.add('formblock__status--error');
          status.textContent = 'Заполните обязательные поля.';
        }
        return;
      }

      e.preventDefault();
      form.setAttribute('aria-busy', 'true');
      submitBtn?.setAttribute('aria-busy', 'true');
      if (submitBtn) submitBtn.disabled = true;

      try {
        const data = new FormData(form);
        const res = await fetch(form.action, { method: 'POST', body: data });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        if (status) {
          status.classList.remove('formblock__status--error');
          status.classList.add('formblock__status--success');
          status.textContent = status.dataset.successText ?? 'Готово.';
        }
        form.reset();
      } catch (_err) {
        if (status) {
          status.classList.remove('formblock__status--success');
          status.classList.add('formblock__status--error');
          status.textContent = status.dataset.errorText ?? 'Ошибка отправки.';
        }
      } finally {
        form.removeAttribute('aria-busy');
        submitBtn?.removeAttribute('aria-busy');
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }

  document.querySelectorAll<HTMLFormElement>('[data-form-id]').forEach(init);
</script>

<style>
  .formblock {
    padding-block: var(--spacing-8);
    background: var(--color-bg-surface);
  }

  .formblock__head { margin-block-end: var(--spacing-6); }
  .formblock__eyebrow {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--font-letter-spacing-widest);
    text-transform: uppercase;
    margin-block-end: var(--spacing-3);
  }
  .formblock__h {
    max-width: 32ch;
    margin-block-end: var(--spacing-3);
  }
  .formblock__desc {
    max-width: 56ch;
    color: var(--color-text-secondary);
    line-height: var(--font-line-height-normal);
  }

  .formblock__form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    max-width: 640px;
    padding: var(--spacing-6);
    background: var(--color-bg-page);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-base);
  }
  .formblock__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }

  .formblock__consent {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-2);
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.5;
    cursor: pointer;
  }
  .formblock__consent-input {
    width: 18px;
    height: 18px;
    margin-block-start: 2px;
    accent-color: var(--color-action-primary);
    flex-shrink: 0;
  }
  .formblock__consent a { color: var(--color-action-primary); text-decoration: underline; text-underline-offset: 0.2em; }

  .formblock__sla {
    margin: 0;
    font-size: var(--font-size-xs);
    color: var(--color-text-tertiary);
    line-height: var(--font-line-height-normal);
  }

  .formblock__status {
    margin: 0;
    min-height: 1.5em;
    font-size: var(--font-size-sm);
    line-height: var(--font-line-height-normal);
  }
  .formblock__status--success {
    padding: var(--spacing-3) var(--spacing-4);
    color: var(--color-feedback-success);
    background: var(--color-bg-surface-warm);
    border-inline-start: 3px solid var(--color-feedback-success);
    border-radius: var(--radius-sm);
  }
  .formblock__status--error {
    padding: var(--spacing-3) var(--spacing-4);
    color: var(--color-feedback-error);
    background: var(--color-feedback-error-bg);
    border-inline-start: 3px solid var(--color-feedback-error);
    border-radius: var(--radius-sm);
  }

  /* После касания submit и при invalid — красные рамки ставит сам Input через aria-invalid;
     дополнительно подсвечиваем :invalid после `is-validated`. */
  .formblock__form.is-validated :global(input:invalid),
  .formblock__form.is-validated :global(textarea:invalid),
  .formblock__form.is-validated :global(select:invalid) {
    border-color: var(--color-feedback-error);
    background: var(--color-feedback-error-bg);
  }

  @media (min-width: 768px) {
    .formblock__row { grid-template-columns: 1fr 1fr; }
  }

  /* B-2: NextStepsList — «Что произойдёт после заявки» (iter3 visual-b2b-audit-loop). */
  .formblock__steps {
    list-style: none; padding: 0; margin: 0 0 var(--spacing-6);
    display: grid; gap: var(--spacing-3); grid-template-columns: 1fr;
  }
  .formblock__step {
    display: flex; gap: var(--spacing-3); align-items: flex-start;
    padding: var(--spacing-3);
    background: color-mix(in srgb, var(--color-action-primary) 4%, var(--color-bg-surface));
    border-left: 3px solid var(--color-action-primary);
    border-radius: var(--radius-sm);
  }
  .formblock__step-num {
    font-family: var(--font-family-monospace);
    color: var(--color-action-primary);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-lg);
    flex: 0 0 auto;
  }
  .formblock__step-title {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.45;
  }
  @media (min-width: 768px) {
    .formblock__steps { grid-template-columns: repeat(4, 1fr); }
  }
</style>
