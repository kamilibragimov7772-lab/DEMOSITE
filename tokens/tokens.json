{
  "$description": "Design tokens for Termy; W3C Design Tokens Community Group draft 2024-2026; phase 3 retro-validation; copied for Astro setup phase 5",
  "$schema": "https://design-tokens.github.io/community-group/format/",

  "color": {
    "primitive": {
      "neutral-0":   { "$value": "#FFFFFF", "$type": "color" },
      "neutral-50":  { "$value": "#FBFAF7", "$type": "color" },
      "neutral-100": { "$value": "#F6F6F4", "$type": "color" },
      "neutral-200": { "$value": "#EFEFEC", "$type": "color" },
      "neutral-300": { "$value": "#E4E6E3", "$type": "color" },
      "neutral-400": { "$value": "#CDD1CC", "$type": "color" },
      "neutral-500": { "$value": "#6A7178", "$type": "color", "$description": "phase-7 iter2 — darkened from #8C949B (2.84:1 fail AA) to #6A7178 (~4.78:1 pass AA) for text-tertiary semantic alias; closes A11y HIGH #1 (155 nodes)" },
      "neutral-700": { "$value": "#5A6368", "$type": "color" },
      "neutral-900": { "$value": "#14181C", "$type": "color" },

      "brand-primary-start": { "$value": "#6428A0", "$type": "color" },
      "brand-primary-mid":   { "$value": "#7D46AF", "$type": "color" },
      "brand-primary-end":   { "$value": "#9466BB", "$type": "color" },

      "shock-start": { "$value": "#A53728", "$type": "color" },
      "shock-mid":   { "$value": "#C84632", "$type": "color" },
      "shock-end":   { "$value": "#EB5A3C", "$type": "color" },

      "temp-cool-start":  { "$value": "#6491B4", "$type": "color" },
      "temp-cool-mid":    { "$value": "#87B4D2", "$type": "color" },
      "temp-cool-end":    { "$value": "#AAD2F5", "$type": "color" },
      "temp-below-start": { "$value": "#913791", "$type": "color" },
      "temp-below-mid":   { "$value": "#B45AB4", "$type": "color" },
      "temp-below-end":   { "$value": "#DC78DC", "$type": "color" },
      "temp-deep-start":  { "$value": "#054B37", "$type": "color" },
      "temp-deep-mid":    { "$value": "#0A5A46", "$type": "color" },
      "temp-deep-end":    { "$value": "#0F6950", "$type": "color" },
      "temp-hot-start":   { "$value": "#EB7D2D", "$type": "color" },
      "temp-hot-mid":     { "$value": "#F09655", "$type": "color" },
      "temp-hot-end":     { "$value": "#F0B47D", "$type": "color" },

      "utility-attention-start": { "$value": "#E6AA23", "$type": "color" },
      "utility-attention-mid":   { "$value": "#EBBE4B", "$type": "color" },
      "utility-attention-end":   { "$value": "#F0CD73", "$type": "color" },

      "utility-information-start": { "$value": "#1E1E50", "$type": "color" },
      "utility-information-mid":   { "$value": "#28286E", "$type": "color" },
      "utility-information-end":   { "$value": "#323287", "$type": "color" },

      "utility-ecology-start": { "$value": "#28A096", "$type": "color" },
      "utility-ecology-mid":   { "$value": "#2DB4AA", "$type": "color" },
      "utility-ecology-end":   { "$value": "#32C8BE", "$type": "color" },
      "utility-ecology-deep":  { "$value": "#1E7A72", "$type": "color" }
    },

    "semantic": {
      "text-primary":     { "$value": "{color.primitive.neutral-900}", "$type": "color" },
      "text-secondary":   { "$value": "{color.primitive.neutral-700}", "$type": "color" },
      "text-tertiary":    { "$value": "{color.primitive.neutral-500}", "$type": "color" },
      "text-on-brand":    { "$value": "{color.primitive.neutral-0}",  "$type": "color" },
      "text-on-dark":     { "$value": "{color.primitive.neutral-0}",  "$type": "color" },
      "text-link":        { "$value": "{color.primitive.brand-primary-start}", "$type": "color" },

      "bg-page":          { "$value": "{color.primitive.neutral-0}",   "$type": "color" },
      "bg-surface":       { "$value": "{color.primitive.neutral-100}", "$type": "color" },
      "bg-surface-warm":  { "$value": "{color.primitive.neutral-50}",  "$type": "color" },
      "bg-dark":          { "$value": "{color.primitive.neutral-900}", "$type": "color" },

      "border-default":   { "$value": "{color.primitive.neutral-300}", "$type": "color" },
      "border-strong":    { "$value": "{color.primitive.neutral-400}", "$type": "color" },
      "border-subtle":    { "$value": "{color.primitive.neutral-200}", "$type": "color" },
      "border-focus":     { "$value": "{color.primitive.brand-primary-mid}", "$type": "color" },

      "action-primary":          { "$value": "{color.primitive.brand-primary-start}", "$type": "color" },
      "action-primary-hover":    { "$value": "{color.primitive.brand-primary-mid}",   "$type": "color" },
      "action-secondary":        { "$value": "{color.primitive.neutral-0}",   "$type": "color" },
      "action-secondary-text":   { "$value": "{color.primitive.neutral-900}", "$type": "color" },

      "feedback-error":     { "$value": "{color.primitive.shock-start}", "$type": "color" },
      "feedback-error-bg":  { "$value": "#FDF3EF", "$type": "color" },
      "feedback-warning":   { "$value": "{color.primitive.utility-attention-start}", "$type": "color" },
      "feedback-success":   { "$value": "{color.primitive.utility-ecology-deep}", "$type": "color" },
      "feedback-info":      { "$value": "{color.primitive.utility-information-end}", "$type": "color" }
    },

    "overlay": {
      "on-dark-low":    { "$value": "rgba(255,255,255,0.04)", "$type": "color", "$description": "phase-6 batch1 — surface overlay над тёмным фоном (footer.price card)" },
      "on-dark-mid":    { "$value": "rgba(255,255,255,0.10)", "$type": "color", "$description": "phase-6 batch1 — border overlay над тёмным фоном (footer.price, legal-strip)" },
      "on-dark-strong": { "$value": "rgba(255,255,255,0.30)", "$type": "color", "$description": "phase-6 batch7 — border overlay для close-кнопок lightbox / overlay UI" },
      "brand-tint-low": { "$value": "rgba(125,70,175,0.08)",  "$type": "color", "$description": "phase-6 batch1 — brand-окрашенный overlay (Input shimmer, hero radial-gradient)" },
      "scrim-mid":      { "$value": "rgba(0,0,0,0.40)",       "$type": "color", "$description": "phase-6 batch7 — lightbox/scrim средняя интенсивность (close-button background)" },
      "scrim-high":     { "$value": "rgba(0,0,0,0.60)",       "$type": "color", "$description": "phase-6 batch7 — lightbox/scrim усиленная (close-button hover)" },
      "scrim-blackout": { "$value": "rgba(0,0,0,0.92)",       "$type": "color", "$description": "phase-6 batch7 — lightbox blackout backdrop" }
    }
  },

  "font": {
    "family": {
      "sans":      { "$value": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif", "$type": "fontFamily" },
      "monospace": { "$value": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace", "$type": "fontFamily" }
    },
    "size": {
      "xs":   { "$value": "0.6875rem", "$type": "dimension" },
      "sm":   { "$value": "0.75rem",   "$type": "dimension" },
      "base": { "$value": "0.875rem",  "$type": "dimension" },
      "md":   { "$value": "1rem",      "$type": "dimension" },
      "lg":   { "$value": "1.125rem",  "$type": "dimension" },
      "xl":   { "$value": "1.25rem",   "$type": "dimension" },
      "2xl":  { "$value": "1.5rem",    "$type": "dimension" },
      "3xl":  { "$value": "1.875rem",  "$type": "dimension" },
      "4xl":  { "$value": "2.125rem",  "$type": "dimension" },
      "5xl":  { "$value": "2.5rem",    "$type": "dimension" },
      "6xl":  { "$value": "3.25rem",   "$type": "dimension" },
      "h1-fluid": { "$value": "clamp(2rem, 4vw, 3.25rem)",     "$type": "dimension" },
      "h2-fluid": { "$value": "clamp(1.5rem, 2.4vw, 2.125rem)", "$type": "dimension" }
    },
    "weight": {
      "regular":   { "$value": 400, "$type": "fontWeight" },
      "medium":    { "$value": 500, "$type": "fontWeight" },
      "semibold":  { "$value": 600, "$type": "fontWeight" },
      "bold":      { "$value": 700, "$type": "fontWeight" },
      "extrabold": { "$value": 800, "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":  { "$value": 1.08, "$type": "number" },
      "snug":   { "$value": 1.15, "$type": "number" },
      "normal": { "$value": 1.5,  "$type": "number" },
      "loose":  { "$value": 1.6,  "$type": "number" }
    },
    "letterSpacing": {
      "tighter": { "$value": "-0.02em",  "$type": "dimension" },
      "tight":   { "$value": "-0.015em", "$type": "dimension" },
      "snug":    { "$value": "-0.01em",  "$type": "dimension" },
      "normal":  { "$value": "0",        "$type": "dimension" },
      "wide":    { "$value": "0.06em",   "$type": "dimension" },
      "wider":   { "$value": "0.08em",   "$type": "dimension" },
      "widest":  { "$value": "0.12em",   "$type": "dimension" }
    }
  },

  "spacing": {
    "0": { "$value": "0",       "$type": "dimension" },
    "1": { "$value": "0.25rem", "$type": "dimension" },
    "2": { "$value": "0.5rem",  "$type": "dimension" },
    "3": { "$value": "0.75rem", "$type": "dimension" },
    "4": { "$value": "1rem",    "$type": "dimension" },
    "5": { "$value": "1.5rem",  "$type": "dimension" },
    "6": { "$value": "2rem",    "$type": "dimension" },
    "7": { "$value": "3rem",    "$type": "dimension" },
    "8": { "$value": "4rem",    "$type": "dimension" },
    "9": { "$value": "6rem",    "$type": "dimension" }
  },

  "radius": {
    "xs":   { "$value": "0.25rem", "$type": "dimension" },
    "sm":   { "$value": "0.5rem",  "$type": "dimension" },
    "base": { "$value": "0.75rem", "$type": "dimension" },
    "lg":   { "$value": "1.25rem", "$type": "dimension" },
    "pill": { "$value": "9999px",  "$type": "dimension" }
  },

  "shadow": {
    "sm":   { "$value": "0 1px 2px rgba(20,24,28,0.05)",  "$type": "shadow" },
    "base": { "$value": "0 6px 18px rgba(20,24,28,0.08)", "$type": "shadow" },
    "lg":   { "$value": "0 16px 40px rgba(100,40,160,0.14)", "$type": "shadow" },
    "compare-tray": { "$value": "0 20px 60px rgba(20,24,28,0.3)", "$type": "shadow" },
    "focus-ring":   { "$value": "0 0 0 3px rgba(125,70,175,0.35)", "$type": "shadow" },
    "focus-ring-error": { "$value": "0 0 0 3px rgba(165,55,40,0.25)", "$type": "shadow", "$description": "phase-6 batch1 — focus ring для invalid input (close MEDIUM hardcoded-rgba)" }
  },

  "duration": {
    "instant": { "$value": "80ms",  "$type": "duration" },
    "fast":    { "$value": "150ms", "$type": "duration" },
    "normal":  { "$value": "250ms", "$type": "duration" },
    "slow":    { "$value": "400ms", "$type": "duration" },
    "hero":    { "$value": "600ms", "$type": "duration" }
  },

  "easing": {
    "standard":   { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
    "decelerate": { "$value": "cubic-bezier(0, 0, 0.2, 1)",   "$type": "cubicBezier" },
    "accelerate": { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier" },
    "linear":     { "$value": "linear", "$type": "cubicBezier" }
  },

  "z": {
    "base":     { "$value": 0,  "$type": "number" },
    "elevated": { "$value": 10, "$type": "number" },
    "sticky":   { "$value": 20, "$type": "number" },
    "compare":  { "$value": 30, "$type": "number" },
    "modal":    { "$value": 50, "$type": "number" },
    "toast":    { "$value": 60, "$type": "number" }
  },

  "breakpoint": {
    "sm":  { "$value": "320px",  "$type": "dimension" },
    "md":  { "$value": "768px",  "$type": "dimension" },
    "lg":  { "$value": "1024px", "$type": "dimension" },
    "xl":  { "$value": "1320px", "$type": "dimension" },
    "2xl": { "$value": "1920px", "$type": "dimension" }
  },

  "container": {
    "max": { "$value": "1320px", "$type": "dimension" }
  }
}
