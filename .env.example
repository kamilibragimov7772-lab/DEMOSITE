# termy-site — production environment variables (template)
#
# Реальные значения — в Vercel Dashboard → Settings → Environment Variables
# (Production scope). НЕ коммитить реальные значения в git.
#
# Локальная разработка: скопируй в .env.local и подставь dev-значения.

# === Public (доступны клиенту, билд-тайм + рантайм) ===
PUBLIC_SITE_URL=https://termy.ru
PUBLIC_PLAUSIBLE_DOMAIN=termy.ru
PUBLIC_SENTRY_DSN=

# === Build-time only (Vercel Build Step) ===
# Sentry source-maps upload. Создать в Sentry → Settings → Auth Tokens.
# Scope: project:releases, project:write
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=termy-site
